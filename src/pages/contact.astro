---
import { Calendar, Mail, Phone } from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { BOOKING_URL } from "@/lib/services";
import { siteMedia } from "@/lib/site-media";
---

<BaseLayout
  title="Contact — Turnkey Marketing"
  description="Contact Turnkey Marketing or book a strategy call to talk through your auto repair shop marketing."
  path="/contact"
  ogTitle="Contact Turnkey Marketing"
  ogImage={siteMedia.team.visionExpoConversation.src}
>
  <section class="border-b hairline bg-white">
    <div class="container-page pt-14 md:pt-20 pb-10 md:pb-14">
      <p class="eyebrow" style="color: var(--key-blue);">Contact</p>
      <h1 class="display-2 mt-5 max-w-[12ch] text-balance">
        Let’s talk about your shop.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted-foreground">
        When you are ready, the booking page handles both scheduling and the
        intake details we need before the call.
      </p>
    </div>
  </section>

  <section class="container-page py-14 md:py-20">
    <div class="grid gap-5 md:grid-cols-3">
      <a
        href={BOOKING_URL}
        class="group rounded-[28px] bg-[var(--navy)] p-7 text-white transition hover:-translate-y-1 hover:shadow-[0_28px_70px_-48px_rgba(35,46,102,0.65)]"
        data-track-event="consultation_cta_click"
        data-track-placement="contact_primary"
      >
        <span
          class="inline-flex h-12 w-12 items-center justify-center rounded-2xl"
          style="background: var(--green); color: var(--charcoal);"
        >
          <Calendar className="h-5 w-5" />
        </span>
        <h2 class="mt-8 font-display text-2xl font-semibold">
          Book a strategy call
        </h2>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
          Pick a time with Chris and share the details in the calendar widget.
        </p>
      </a>

      <a
        href="tel:9137774144"
        class="rounded-[28px] bg-[var(--off-white)] p-7 transition hover:-translate-y-1 hover:shadow-[0_28px_70px_-48px_rgba(20,22,28,0.3)]"
        data-track-event="phone_click"
        data-track-placement="contact"
      >
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--key-blue-soft)] text-[var(--navy)]">
          <Phone className="h-5 w-5" />
        </span>
        <h2 class="mt-8 font-display text-2xl font-semibold text-charcoal">
          Call the team
        </h2>
        <p class="mt-3 text-lg font-medium text-charcoal">(913) 777-4144</p>
      </a>

      <a
        href="mailto:hello@turnkeyautomarketing.com"
        class="rounded-[28px] bg-[var(--off-white)] p-7 transition hover:-translate-y-1 hover:shadow-[0_28px_70px_-48px_rgba(20,22,28,0.3)]"
        data-track-event="email_click"
        data-track-placement="contact"
      >
        <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-[var(--key-blue-soft)] text-[var(--navy)]">
          <Mail className="h-5 w-5" />
        </span>
        <h2 class="mt-8 font-display text-2xl font-semibold text-charcoal">
          Email us
        </h2>
        <p class="mt-3 break-words text-lg font-medium text-charcoal">
          hello@turnkeyautomarketing.com
        </p>
      </a>
    </div>
  </section>
</BaseLayout>
