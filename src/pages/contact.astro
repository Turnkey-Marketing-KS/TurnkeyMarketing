---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteMedia } from "@/lib/site-media";
---

<BaseLayout
  title="Contact — Turnkey Marketing"
  description="Start with the Turnkey Marketing lead form, then continue to book a strategy call with our team."
  path="/contact"
  ogTitle="Contact Turnkey Marketing"
  ogImage={siteMedia.team.visionExpoConversation.src}
>
  <section class="border-b hairline bg-white">
    <div class="container-page pt-14 md:pt-20 pb-10 md:pb-14">
      <p class="eyebrow" style="color: var(--key-blue);">Contact</p>
      <h1 class="display-2 mt-5 max-w-[12ch] text-balance">
        Let’s talk about your shop.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted-foreground">
        Start with the basics below. Then book your strategy call so we can
        talk through what is working, what is leaking, and what should happen
        next.
      </p>
    </div>
  </section>

  <section id="website-lead-form" class="container-page py-12 md:py-16">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
      <div class="lg:col-span-4 lg:sticky lg:top-32">
        <p class="eyebrow">Step 1 of 2</p>
        <div class="mt-8 rounded-[24px] bg-[var(--off-white)] p-6">
          <p class="text-sm font-medium text-charcoal">Next step</p>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
            After the form, continue to the booking page so the call is already
            connected to the details you shared.
          </p>
        </div>
      </div>
      <div class="lg:col-span-8">
        <iframe
          src="https://api.leadconnectorhq.com/widget/form/P1f7GUG9biZuo9nQ4O0m"
          style="width:100%;height:1500px;border:none;background:#fff;display:block"
          id="inline-P1f7GUG9biZuo9nQ4O0m"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="Website Lead Form — Turnkey"
          data-height="1320"
          data-layout-iframe-id="inline-P1f7GUG9biZuo9nQ4O0m"
          data-form-id="P1f7GUG9biZuo9nQ4O0m"
          title="Website Lead Form — Turnkey"
          loading="lazy"
        >
        </iframe>
      </div>
    </div>
  </section>
</BaseLayout>
