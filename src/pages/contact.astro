---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact — Turnkey Marketing"
  description="Submit the Turnkey Marketing contact form, schedule a consultation, call, or email our team."
  path="/contact"
  ogTitle="Contact Turnkey Marketing"
>
  <section class="border-b hairline">
    <div class="container-page pt-20 md:pt-28 pb-16">
      <p class="eyebrow">Contact</p>
      <h1 class="display-1 mt-6 max-w-[16ch] text-balance">
        Let's talk about your shop.
      </h1>
      <p class="mt-8 text-lg text-muted-foreground max-w-2xl">
        30 minutes. No pitch deck. Just a real conversation about what is
        working, what is leaking, and what the first 90-120 days should
        realistically focus on.
      </p>
    </div>
  </section>

  <section id="website-lead-form" class="container-page py-20 md:py-24">
    <div class="grid gap-10 lg:grid-cols-12 lg:items-start">
      <div class="lg:col-span-4 lg:sticky lg:top-32">
        <p class="eyebrow">Website lead form</p>
        <h2 class="display-3 mt-5 max-w-[12ch] text-balance">
          Tell us what you are trying to sort out.
        </h2>
        <p class="mt-5 text-muted-foreground leading-relaxed">
          Share the basics about your shop, your current marketing, and what
          needs to get clearer. Our team will use it to make the first
          conversation more useful.
        </p>
      </div>
      <div class="lg:col-span-8">
        <div class="overflow-hidden rounded-2xl border hairline bg-white shadow-[0_24px_70px_-40px_rgba(20,22,28,0.35)]">
          <iframe
            src="https://api.leadconnectorhq.com/widget/form/P1f7GUG9biZuo9nQ4O0m"
            style="width:100%;height:1320px;border:none;border-radius:8px"
            id="inline-P1f7GUG9biZuo9nQ4O0m"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-trigger-value=""
            data-activation-type="alwaysActivated"
            data-activation-value=""
            data-deactivation-type="neverDeactivate"
            data-deactivation-value=""
            data-form-name="Website Lead Form — Turnkey"
            data-height="1320"
            data-layout-iframe-id="inline-P1f7GUG9biZuo9nQ4O0m"
            data-form-id="P1f7GUG9biZuo9nQ4O0m"
            title="Website Lead Form — Turnkey"
            loading="lazy"
          >
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <script is:inline src="https://link.msgsndr.com/js/form_embed.js"></script>
</BaseLayout>
