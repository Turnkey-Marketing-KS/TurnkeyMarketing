---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteMedia } from "@/lib/site-media";
import { resourcePosts } from "@/lib/resource-posts";

const [featuredPost, ...secondaryPosts] = resourcePosts;
const resourceFilters = ["All", ...Array.from(new Set(resourcePosts.map((post) => post.tag)))];
const filterSlug = (filter: string) => filter.toLowerCase().replaceAll(" ", "-");
---

<BaseLayout
  title="Auto Repair Marketing Resources — Turnkey Marketing"
  description="Auto repair marketing articles, guides, and tools for shop owners who want clearer spend, better follow-up, and less guesswork."
  path="/resources"
  ogTitle="Auto Repair Marketing Resources — Turnkey Marketing"
  ogImage={siteMedia.graphics.leadGenerator.src}
>
  <section class="bg-[var(--off-white)] py-6 md:py-10 lg:py-14">
    <div class="container-page">
      <header class="min-w-0 overflow-hidden rounded-[28px] border border-black/[0.04] bg-white px-5 py-8 shadow-[0_24px_70px_-54px_rgba(20,22,28,0.5)] md:rounded-[34px] md:px-10 md:py-12 lg:px-14 lg:py-14">
        <div class="grid gap-8 lg:grid-cols-[1fr_0.82fr] lg:items-end lg:gap-16">
          <div class="min-w-0">
            <p class="eyebrow text-[var(--key-blue)]">Resources</p>
            <h1 class="display-2 mt-5 max-w-4xl text-balance">
              Better marketing decisions, built for busy bays.
            </h1>
          </div>
          <p class="max-w-2xl text-base leading-relaxed text-charcoal/65 md:text-lg lg:pb-1">
            Practical articles for shop owners who want clearer marketing
            decisions, stronger vendor accountability, and less guesswork
            around what to run next.
          </p>
        </div>

        <div class="mt-9 border-t border-[var(--hairline)] pt-6 md:mt-11 md:flex md:items-center md:gap-6 md:pt-7">
          <p class="mb-3 shrink-0 text-sm font-semibold text-charcoal md:mb-0">Browse by topic</p>
          <div
            class="no-scrollbar resource-filter-bar relative isolate flex max-w-full scroll-px-1 gap-1 overflow-x-auto rounded-full bg-[var(--off-white)] p-1 md:inline-flex"
            data-resource-filter-bar
            role="tablist"
            aria-label="Filter resources"
          >
            <span
              class="pointer-events-none absolute bottom-1 top-1 rounded-full bg-charcoal transition-[transform,width] duration-300 ease-out"
              data-resource-filter-indicator
              aria-hidden="true"
            ></span>
            {resourceFilters.map((filter, index) => (
              <button
                type="button"
                data-resource-filter={filter}
                data-resource-filter-slug={filterSlug(filter)}
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                class="relative z-10 shrink-0 rounded-full px-4 py-2.5 text-sm font-medium text-charcoal/70 transition-colors duration-75 md:px-5"
              >
                {filter}
              </button>
            ))}
          </div>
        </div>
      </header>

      <section class="mt-14 md:mt-20" aria-labelledby="resource-library-heading">
        <div class="flex items-end justify-between gap-4 border-b border-charcoal/10 pb-5 md:pb-6">
          <div>
            <p class="eyebrow text-[var(--key-blue)]">The library</p>
            <h2 id="resource-library-heading" class="mt-2 font-display text-2xl font-semibold text-charcoal md:text-3xl">
              Explore the resources
            </h2>
          </div>
          <p class="shrink-0 text-sm text-charcoal/55" aria-live="polite" data-resource-count>
            {resourcePosts.length} resources
          </p>
        </div>

      {featuredPost && (
        <div
          class="mt-8 md:mt-10"
          data-resource-card
          data-resource-tag={featuredPost.tag}
        >
          <div class="mb-4 flex items-center gap-3 md:mb-5">
            <span class="h-2 w-2 rounded-full bg-[var(--green)]"></span>
            <p class="eyebrow text-charcoal/60">Featured resource</p>
          </div>
          <a
            href={featuredPost.href}
            class="group grid min-w-0 overflow-hidden rounded-[28px] border border-black/[0.06] bg-white shadow-[0_24px_70px_-54px_rgba(20,22,28,0.55)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_80px_-48px_rgba(20,22,28,0.5)] lg:grid-cols-[1.1fr_0.9fr] lg:items-stretch"
          >
            <div class="aspect-[16/9] overflow-hidden bg-[var(--off-white)] lg:min-h-[430px] lg:aspect-auto">
              <img
                src={featuredPost.image.src}
                alt={featuredPost.image.alt}
                width="1400"
                height="790"
                loading="eager"
                decoding="async"
                class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.025]"
                style={`object-position: ${featuredPost.image.position};`}
              />
            </div>
            <article class="flex min-w-0 flex-col justify-center px-5 py-7 md:px-9 md:py-10 lg:px-12">
              <div class="flex flex-wrap items-center gap-2.5 text-sm text-charcoal/50">
                <span class="rounded-full bg-[var(--key-blue-soft)] px-3 py-1 text-xs font-semibold text-[var(--navy)]">
                  {featuredPost.tag}
                </span>
                <span aria-hidden="true">·</span>
                <span>{featuredPost.date}</span>
              </div>
              <h2 class="mt-5 max-w-[20ch] font-display text-2xl font-semibold leading-[1.08] text-charcoal text-balance md:text-3xl lg:text-4xl">
                {featuredPost.title}
              </h2>
              <p class="mt-4 max-w-xl text-base leading-relaxed text-charcoal/65 md:mt-5 md:text-lg">
                {featuredPost.dek}
              </p>
              <span class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-[var(--navy)]">
                Read article
                <span class="motion-arrow">→</span>
              </span>
            </article>
          </a>
        </div>
      )}

        <div class="mt-6 grid gap-6 md:mt-8 md:grid-cols-2 lg:gap-7">
          {secondaryPosts.map((item) => (
            <a
              href={item.href}
              id={filterSlug(item.tag)}
              data-resource-card
              data-resource-tag={item.tag}
              class="group flex h-full min-w-0 flex-col overflow-hidden rounded-[24px] border border-black/[0.06] bg-white shadow-[0_18px_55px_-48px_rgba(20,22,28,0.55)] transition duration-300 hover:-translate-y-1 hover:border-black/10 hover:shadow-[0_28px_70px_-46px_rgba(20,22,28,0.48)] md:rounded-[28px]"
            >
              <div class="aspect-[16/10] overflow-hidden border-b border-black/[0.05] bg-[var(--off-white)]">
                <img
                  src={item.image.src}
                  alt={item.image.alt}
                  width="1000"
                  height="625"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
                  style={`object-position: ${item.image.position};`}
                />
              </div>
              <div class="flex flex-1 flex-col px-5 py-6 md:px-7 md:py-7">
                <div class="flex flex-wrap items-center gap-2.5 text-sm text-charcoal/50">
                  <span class="rounded-full bg-[var(--off-white)] px-3 py-1 text-xs font-semibold text-charcoal">
                    {item.tag}
                  </span>
                  <span aria-hidden="true">·</span>
                  <span>{item.date}</span>
                </div>
                <h3 class="mt-4 max-w-[22ch] font-display text-2xl font-semibold leading-[1.1] text-charcoal text-balance md:text-[1.7rem]">
                  {item.title}
                </h3>
                <p class="mt-4 max-w-xl text-base leading-relaxed text-charcoal/65">
                  {item.description}
                </p>
                <span class="mt-6 inline-flex items-center gap-2 pt-1 text-sm font-semibold text-[var(--navy)]">
                  Read article
                  <span class="motion-arrow">→</span>
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>

  <script>
    const initResourceFilters = () => {
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const bar = document.querySelector("[data-resource-filter-bar]");
      const indicator = document.querySelector("[data-resource-filter-indicator]");
      const buttons = Array.from(document.querySelectorAll("[data-resource-filter]"));
      const cards = Array.from(document.querySelectorAll("[data-resource-card]"));
      const count = document.querySelector("[data-resource-count]");

      if (!(bar instanceof HTMLElement) || !(indicator instanceof HTMLElement) || buttons.length === 0) {
        return;
      }

      const moveIndicator = (button) => {
        if (!(button instanceof HTMLElement)) return;
        indicator.style.width = `${button.offsetWidth}px`;
        indicator.style.transform = `translateX(${button.offsetLeft}px)`;
      };

      const setActiveFilter = (filter, updateHash = true) => {
        const activeButton = buttons.find((button) => button.getAttribute("data-resource-filter") === filter);
        if (!(activeButton instanceof HTMLElement)) return;

        buttons.forEach((button) => {
          const isActive = button === activeButton;
          button.setAttribute("aria-selected", isActive ? "true" : "false");
          button.toggleAttribute("data-active", isActive);
          if (button instanceof HTMLElement) {
            button.style.color = isActive ? "#fff" : "";
          }
        });

        cards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;

          const shouldShow = filter === "All" || card.getAttribute("data-resource-tag") === filter;
          if (shouldShow) {
            card.hidden = false;
            card.style.opacity = "0";
            window.requestAnimationFrame(() => {
              card.style.opacity = "1";
            });
          } else {
            card.style.opacity = "0";
            window.setTimeout(() => {
              if (card.style.opacity === "0") {
                card.hidden = true;
              }
            }, 180);
          }
        });

        if (count instanceof HTMLElement) {
          const visibleCount = cards.filter(
            (card) => filter === "All" || card.getAttribute("data-resource-tag") === filter,
          ).length;
          count.textContent = `${visibleCount} ${visibleCount === 1 ? "resource" : "resources"}`;
        }

        window.requestAnimationFrame(() => {
          moveIndicator(activeButton);
        });

        if (updateHash) {
          const slug = activeButton.getAttribute("data-resource-filter-slug");
          const nextUrl = filter === "All" ? "/resources" : `/resources#${slug}`;
          window.history.replaceState(null, "", nextUrl);
        }
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          setActiveFilter(button.getAttribute("data-resource-filter") ?? "All");
          if (button instanceof HTMLElement) {
            button.scrollIntoView({
              behavior: reducedMotion ? "auto" : "smooth",
              block: "nearest",
              inline: "center",
            });
          }
        });
      });

      const initialSlug = window.location.hash.replace("#", "");
      const initialButton = buttons.find(
        (button) => button.getAttribute("data-resource-filter-slug") === initialSlug,
      );
      setActiveFilter(initialButton?.getAttribute("data-resource-filter") ?? "All", false);
      window.addEventListener("resize", () => {
        const activeButton = buttons.find((button) => button.getAttribute("aria-selected") === "true");
        moveIndicator(activeButton);
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initResourceFilters, { once: true });
    } else {
      initResourceFilters();
    }
  </script>

  <style>
    .resource-filter-bar [data-resource-filter] {
      transition:
        color 0ms linear,
        transform 260ms var(--ease-emphasized);
    }

    .resource-filter-bar [data-resource-filter][data-active] {
      color: #fff;
    }

    [data-resource-card] {
      transition:
        opacity 180ms ease,
        transform 260ms var(--ease-emphasized);
    }

    @media (max-width: 480px) {
      .resource-filter-bar {
        border-radius: 1.5rem;
      }
    }
  </style>
</BaseLayout>
