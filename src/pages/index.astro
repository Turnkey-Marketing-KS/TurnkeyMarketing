<style>
  [data-hero-phrase] {
    font-variant-ligatures: none;
  }

  [data-hero-cursor] {
    display: inline-block;
    margin-left: 0.04em;
    animation: hero-cursor-blink 1s steps(2, start) infinite;
    color: var(--key-blue);
  }

  @keyframes hero-cursor-blink {
    50% {
      opacity: 0;
    }
  }

  .faq-item > summary {
    list-style: none;
  }

  .faq-item > summary::-webkit-details-marker {
    display: none;
  }

  .faq-minus {
    display: none;
  }

  .faq-item[open] .faq-plus {
    display: none;
  }

  .faq-item[open] .faq-minus {
    display: inline;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-hero-cursor] {
      animation: none;
      opacity: 0;
    }
  }
</style>

<script>
  const phrase = document.querySelector("[data-hero-phrase]");
  const phraseText = document.querySelector("[data-hero-phrase-text]");
  const phrases = phrase ? JSON.parse(phrase.dataset.phrases || "[]") : [];
  let phraseIndex = 0;

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (phraseText && phrases.length > 1 && !reduceMotion) {
    const typeSpeed = 42;
    const deleteSpeed = 22;
    const holdDelay = 1550;
    const betweenDelay = 180;

    const typePhrase = (text, charIndex = 0) => {
      phraseText.textContent = text.slice(0, charIndex);
      if (charIndex < text.length) {
        window.setTimeout(() => typePhrase(text, charIndex + 1), typeSpeed);
        return;
      }
      window.setTimeout(() => deletePhrase(text, text.length), holdDelay);
    };

    const deletePhrase = (text, charIndex) => {
      phraseText.textContent = text.slice(0, charIndex);
      if (charIndex > 0) {
        window.setTimeout(() => deletePhrase(text, charIndex - 1), deleteSpeed);
        return;
      }
      phraseIndex = (phraseIndex + 1) % phrases.length;
      window.setTimeout(() => typePhrase(phrases[phraseIndex]), betweenDelay);
    };

    window.setTimeout(() => deletePhrase(phrases[0], phrases[0].length), holdDelay);
  }

</script>
