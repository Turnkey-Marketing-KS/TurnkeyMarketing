    display: none;
  }

  .faq-item[open] .faq-minus {
    display: inline;
  }

  .faq-toggle-icon {
    transition: transform var(--duration-standard) var(--ease-emphasized);
  }

  .faq-toggle[aria-expanded="true"] .faq-toggle-icon {
    transform: rotate(180deg);
  }

  @media (max-width: 767px) {
    .faq-extra {
      display: none;
    }

    .faq-list.is-expanded .faq-extra {
      display: block;
    }
  }

  @media (min-width: 768px) {
    .hero-rotator {
      margin-top: 0.18em;
    }

    .hero-rotator-phrase {
      font-size: clamp(2rem, 4.75vw, 3rem);
      line-height: 1.08;
      white-space: nowrap;
    }
  }
</style>

<script>
  const reduceMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
  const reduceMotion = reduceMotionQuery.matches;

  const rotator = document.querySelector<HTMLElement>("[data-hero-rotator]");

  if (rotator) {
    const rotatorPhrases = Array.from(
      rotator.querySelectorAll<HTMLElement>(".hero-rotator-phrase"),
    );
    let activePhrase = 0;
    let rotatorTimer = 0;

    const advancePhrase = () => {
      rotatorPhrases[activePhrase]?.classList.remove("is-active");
      activePhrase = (activePhrase + 1) % rotatorPhrases.length;
      rotatorPhrases[activePhrase]?.classList.add("is-active");
    };

    const syncRotator = () => {
      window.clearInterval(rotatorTimer);
      if (rotatorPhrases.length > 1 && !reduceMotionQuery.matches && !document.hidden) {
        rotatorTimer = window.setInterval(advancePhrase, 2800);
      }
    };

    syncRotator();
    reduceMotionQuery.addEventListener("change", syncRotator);
    document.addEventListener("visibilitychange", syncRotator);
  }

  const featureIcons = document.querySelectorAll("[data-feature-icon]");

  if (featureIcons.length && !reduceMotion) {
    const featureIconObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-visible", entry.isIntersecting);
        });
      },
      { threshold: 0.45 },
    );

    featureIcons.forEach((icon) => featureIconObserver.observe(icon));
  }

  const statsGrid = document.querySelector("[data-stats-grid]");
  const statCounters = Array.from(
    document.querySelectorAll<HTMLElement>("[data-count-up]"),
  );

  if (
    statsGrid &&
    statCounters.length &&
    !reduceMotion &&
    "IntersectionObserver" in window
  ) {
    const getStatParts = (raw: string) => {
      const numericText = raw.match(/\d+(?:\.\d+)?/)?.[0] ?? "0";
      const numericIndex = raw.indexOf(numericText);
      return {
        target: Number(numericText),
        decimals: numericText.includes(".") ? numericText.split(".")[1].length : 0,
        prefix: raw.slice(0, numericIndex),
        suffix: raw.slice(numericIndex + numericText.length),
      };
    };

    statCounters.forEach((counter) => {
      const raw = counter.dataset.countUp || counter.textContent || "0";
      const { decimals, prefix, suffix } = getStatParts(raw);
      counter.textContent = `${prefix}${(0).toFixed(decimals)}${suffix}`;
    });

    const statsObserver = new IntersectionObserver(
      (entries, observer) => {
        const entry = entries[0];
        if (!entry?.isIntersecting) return;

        statCounters.forEach((counter, index) => {
          const raw = counter.dataset.countUp || counter.textContent || "0";
          const { target, decimals, prefix, suffix } = getStatParts(raw);
          const duration = 2000;

          window.setTimeout(() => {
            const startTime = performance.now();

            const updateCounter = (now: number) => {
              const progress = Math.min((now - startTime) / duration, 1);
              const easedProgress = Math.sin((progress * Math.PI) / 2);
              const value = target * easedProgress;
              const formattedValue = decimals
                ? value.toFixed(decimals)
                : Math.floor(value).toLocaleString();

              counter.textContent = `${prefix}${formattedValue}${suffix}`;

              if (progress < 1) {
                requestAnimationFrame(updateCounter);
              } else {
                counter.textContent = raw;
              }
            };

            requestAnimationFrame(updateCounter);
          }, index * 80);
        });

        observer.unobserve(entry.target);
      },
      { threshold: 0.35 },
    );

    statsObserver.observe(statsGrid);
  }

  const faqList = document.querySelector("[data-faq-list]");
  const faqToggle = document.querySelector("[data-faq-toggle]");
  const faqToggleLabel = document.querySelector("[data-faq-toggle-label]");

  if (faqList && faqToggle && faqToggleLabel) {
    const faqCollapsedLabel = faqToggleLabel.textContent?.trim() || "View more questions";

    faqToggle.addEventListener("click", () => {
      const expanded = faqToggle.getAttribute("aria-expanded") === "true";
      const nextExpanded = !expanded;
      const toggleTopBefore = faqToggle.getBoundingClientRect().top;

      faqList.classList.toggle("is-expanded", nextExpanded);
      faqToggle.setAttribute("aria-expanded", String(nextExpanded));
      faqToggleLabel.textContent = nextExpanded
        ? "Show fewer questions"
        : faqCollapsedLabel;

      if (!nextExpanded) {
        faqList.querySelectorAll(".faq-extra[open]").forEach((item) => {
          item.removeAttribute("open");
        });

        const restoreTogglePosition = () => {
          const toggleTopAfter = faqToggle.getBoundingClientRect().top;
          window.scrollBy(0, toggleTopAfter - toggleTopBefore);
        };

        restoreTogglePosition();
        requestAnimationFrame(() => {
          restoreTogglePosition();
          requestAnimationFrame(restoreTogglePosition);
        });
      }
    });
  }

</script>
