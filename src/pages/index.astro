</style>

<script>
  const phrase = document.querySelector<HTMLElement>("[data-hero-phrase]");
  const phrases = phrase ? JSON.parse(phrase.dataset.phrases || "[]") : [];
  let phraseIndex = 0;

  if (phrase && phrases.length > 1) {
    window.setInterval(() => {
      phrase.classList.add("is-changing");
      window.setTimeout(() => {
        phraseIndex = (phraseIndex + 1) % phrases.length;
        phrase.textContent = phrases[phraseIndex];
        phrase.classList.remove("is-changing");
      }, 280);
    }, 2600);
  }

  const capabilityRoot = document.querySelector<HTMLElement>("[data-capability-showcase]");

  if (capabilityRoot) {
    const triggers = Array.from(
      capabilityRoot.querySelectorAll<HTMLElement>("[data-capability-trigger]"),
    );
    const panels = Array.from(
      capabilityRoot.querySelectorAll<HTMLElement>("[data-capability-panel]"),
    );
    const images = Array.from(
      capabilityRoot.querySelectorAll<HTMLElement>("[data-capability-image]"),
    );
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const compactViewport = window.matchMedia("(max-width: 767px)").matches;
    let activeIndex = 0;
    let rotateTimer: number | undefined;

    const setActiveCapability = (nextIndex: number) => {
      activeIndex = nextIndex;
      capabilityRoot.dataset.activeAccent =
        triggers[nextIndex]?.dataset.capabilityAccent || "blue";

      if (compactViewport) {
        triggers[nextIndex]?.scrollIntoView({
          block: "nearest",
          inline: "center",
          behavior: reduceMotion ? "auto" : "smooth",
        });
      }

      triggers.forEach((trigger, index) => {
        const isActive = index === nextIndex;
        trigger.classList.toggle("is-active", isActive);
        trigger.setAttribute("aria-pressed", String(isActive));
      });

      panels.forEach((panel, index) => {
        const isActive = index === nextIndex;
        panel.classList.toggle("is-active", isActive);
        panel.setAttribute("aria-hidden", String(!isActive));
      });

      images.forEach((image, index) => {
        const isActive = index === nextIndex;
        image.classList.toggle("is-active", isActive);
        image.setAttribute("aria-hidden", String(!isActive));
      });
    };

    const stopRotation = () => {
      if (rotateTimer) {
        window.clearInterval(rotateTimer);
        rotateTimer = undefined;
      }
    };

    const startRotation = () => {
      if (reduceMotion || compactViewport || triggers.length < 2) return;
      stopRotation();
      rotateTimer = window.setInterval(() => {
        setActiveCapability((activeIndex + 1) % triggers.length);
      }, 3600);
    };

    triggers.forEach((trigger, index) => {
      const selectCapability = () => {
        stopRotation();
        setActiveCapability(index);
      };

      trigger.addEventListener("mouseenter", selectCapability);
      trigger.addEventListener("focus", selectCapability);
      trigger.addEventListener("click", selectCapability);
    });

    capabilityRoot.addEventListener("mouseenter", stopRotation);
    capabilityRoot.addEventListener("focusin", stopRotation);
    capabilityRoot.addEventListener("mouseleave", startRotation);

    startRotation();
  }
</script>
