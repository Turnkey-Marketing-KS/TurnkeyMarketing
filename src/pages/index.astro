<style>
  [data-hero-phrase] {
    transition: opacity 0.28s ease, transform 0.28s ease;
  }

  [data-hero-phrase].is-changing {
    opacity: 0;
    transform: translateY(0.16em);
  }

  .faq-item > summary {
    list-style: none;
  }

  .faq-item > summary::-webkit-details-marker {
    display: none;
  }

  .faq-minus {
    display: none;
  }

  .faq-item[open] .faq-plus {
    display: none;
  }

  .faq-item[open] .faq-minus {
    display: inline;
  }
</style>

<script>
  const phrase = document.querySelector<HTMLElement>("[data-hero-phrase]");
  const phrases = phrase ? JSON.parse(phrase.dataset.phrases || "[]") : [];
  let phraseIndex = 0;

  if (phrase && phrases.length > 1) {
    window.setInterval(() => {
      phrase.classList.add("is-changing");
      window.setTimeout(() => {
        phraseIndex = (phraseIndex + 1) % phrases.length;
        phrase.textContent = phrases[phraseIndex];
        phrase.classList.remove("is-changing");
      }, 280);
    }, 2600);
  }
</script>
