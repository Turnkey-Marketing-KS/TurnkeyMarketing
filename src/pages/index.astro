<style>
  [data-hero-phrase] {
    transition: opacity 0.28s ease, transform 0.28s ease;
  }

  [data-hero-phrase].is-changing {
    opacity: 0;
    transform: translateY(0.16em);
  }

  .capability-shell {
    animation: capability-shell-in 0.75s cubic-bezier(0.21, 0.86, 0.32, 1) both;
  }

  .capability-selector > * + * {
    margin-top: 0.5rem;
  }

  .capability-option {
    transform-origin: left center;
    transition:
      color 0.32s ease,
      opacity 0.32s ease,
      transform 0.32s ease;
  }

  .capability-option:hover,
  .capability-option:focus-visible,
  .capability-option.is-active {
    color: var(--capability-accent, var(--key-blue));
    opacity: 1;
    transform: translateX(0.18em);
  }

  .capability-option:focus-visible {
    border-radius: 0.2em;
    box-shadow: 0 0 0 3px rgba(63, 140, 203, 0.18);
  }

  .capability-panel {
    inset: 0;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    transform: translateY(18px);
    visibility: hidden;
    transition:
      opacity 0.34s ease,
      transform 0.42s cubic-bezier(0.21, 0.86, 0.32, 1);
  }

  .capability-panel.is-active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
    transform: translateY(0);
    visibility: visible;
  }

  .capability-panel.is-active .capability-heading {
    color: var(--capability-accent, var(--charcoal));
  }

  .capability-image-stage {
    box-shadow: 0 34px 90px -58px rgba(20, 22, 28, 0.38);
    transition: box-shadow 0.35s ease, outline-color 0.35s ease;
    outline: 1px solid transparent;
    outline-offset: 0;
  }

  .capability-showcase-section[data-active-accent="green"] .capability-image-stage {
    box-shadow: 0 34px 90px -56px rgba(147, 200, 69, 0.55);
    outline-color: rgba(147, 200, 69, 0.28);
  }

  .capability-image {
    opacity: 0;
    transform: scale(1.045) translateY(16px);
    visibility: hidden;
    transition:
      opacity 0.45s ease,
      transform 0.72s cubic-bezier(0.21, 0.86, 0.32, 1);
  }

  .capability-image.is-active {
    opacity: 1;
    transform: scale(1) translateY(0);
    visibility: visible;
  }

  @keyframes capability-shell-in {
    from {
      opacity: 0;
      transform: translateY(22px);
    }
    to {
      opacity: 1;
