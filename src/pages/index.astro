---
import {
  ArrowRight,
  BarChart3,
  ChevronDown,
  Compass,
  Crown,
  Globe,
  Mail,
  Phone,
  Quote,
  Repeat,
  Rocket,
  Route,
  Share2,
  Star,
  Target,
  TrendingUp,
  Zap,
} from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CONSULTATION_URL, services } from "@/lib/services";
import { getServiceDetail } from "@/lib/service-details";
import { siteMedia } from "@/lib/site-media";
import { resourcePosts } from "@/lib/resource-posts";
import { ownerTestimonials } from "@/lib/proof";
import { googleReviewHighlights } from "@/lib/google-reviews";

const heroPhrases = [
  "that increases car count.",
  "that gets the phone ringing.",
  "that brings customers back.",
  "that proves what is working.",
  "that gets it off your plate.",
];

const shopLogos = [
  { name: "D&E Auto Repair", src: "/images/trust-logos/vip/01-d-and-e-auto-repair.webp" },
  { name: "Super Service of Aliso Viejo", src: "/images/trust-logos/vip/02-super-service-of-aliso-viejo.webp" },
  { name: "CDT Automotive", src: "/images/trust-logos/vip/03-cdt-automotive.webp" },
  { name: "Fast Lane Automotive", src: "/images/trust-logos/vip/04-fast-lane-automotive.webp" },
  { name: "Budd & Company Automotive", src: "/images/trust-logos/vip/05-budd-and-company-automotive-mlk.webp" },
  { name: "Keeton Euro Repair", src: "/images/trust-logos/vip/06-keeton-euro-repair.webp" },
  { name: "Ingolstadt West", src: "/images/trust-logos/vip/07-ingolstadt-west.webp" },
  { name: "Chris Matthews Automotive", src: "/images/trust-logos/vip/08-chris-matthews-automotive.webp" },
  { name: "Japanese Car Care", src: "/images/trust-logos/vip/09-japanese-car-care-east.webp" },
  { name: "Cherry Lane Auto Repair", src: "/images/trust-logos/vip/10-cherry-lane-auto-repair.webp" },
  { name: "CarFix", src: "/images/trust-logos/vip/11-carfix-mast-dr.webp" },
  { name: "Pristal's Automotive", src: "/images/trust-logos/vip/12-pristal-s-automotive-inc.webp" },
  { name: "Boradori Automotive", src: "/images/trust-logos/vip/13-boradori-automotive-marysville.webp" },
  { name: "Al Huss Auto & Truck", src: "/images/trust-logos/vip/14-al-huss-auto-and-truck.webp" },
  { name: "AutoWorks of Tampa", src: "/images/trust-logos/vip/15-autoworks-of-tampa.webp" },
  { name: "Pit Shop Auto Repair", src: "/images/trust-logos/vip/16-pit-shop-auto-repair-libertyville.webp" },
  { name: "Eurotech Car Care", src: "/images/trust-logos/vip/17-eurotech-car-care.webp" },
  { name: "Kay Jay's Auto Repair", src: "/images/trust-logos/vip/18-kay-jay-s-auto-repair.webp" },
  { name: "Koffman AutoWorks", src: "/images/trust-logos/vip/19-koffman-autoworks.webp" },
  { name: "Pro Automotive", src: "/images/trust-logos/vip/20-pro-automotive-191-west-main-dudley.webp" },
  { name: "Keeton Auto Repair", src: "/images/trust-logos/vip/21-keeton-auto-repair.webp" },
  { name: "Horizon Auto Center", src: "/images/trust-logos/vip/22-horizon-auto-center.webp" },
  { name: "Garage Guys Automotive", src: "/images/trust-logos/vip/23-garage-guys-automotive-richmond.webp" },
  { name: "Choisser Automotive Services", src: "/images/trust-logos/vip/24-choisser-automotive-services-of-davidsonville.webp" },
  { name: "Craftsman Auto Care", src: "/images/trust-logos/vip/25-craftsman-auto-care.webp" },
  { name: "APEX Auto & RV Repair", src: "/images/trust-logos/vip/26-apex-auto-and-rv-repair.webp" },
  { name: "inMOTION Auto Care", src: "/images/trust-logos/vip/27-inmotion-auto-care.webp" },
  { name: "Gene's 112 Auto Service Center", src: "/images/trust-logos/vip/28-gene-s-112-auto-service-center.webp" },
  { name: "Killian Auto Pros", src: "/images/trust-logos/vip/29-killian-auto-pros-greenville.webp" },
  { name: "Certified Auto Repair", src: "/images/trust-logos/vip/30-certified-auto-repair.webp" },
];

const logoCloudRows = [
  shopLogos.slice(0, 15),
  shopLogos.slice(15),
];

const mobileTrustLogos = shopLogos.slice(0, 12).map((logo) => ({ ...logo, scale: 1 }));

const stats = [
  { k: "300+", v: "Auto repair shops served across the U.S." },
  { k: "13+", v: "Years marketing exclusively for shop owners" },
  { k: "5.0★", v: "Google rating from shop owners and clients", accent: true },
];

const reviewLoop = [...googleReviewHighlights, ...googleReviewHighlights];
const mobileTrustReview = googleReviewHighlights[2];

const serviceIcons: Record<string, typeof Crown> = {
  "vip-marketing-manager": Crown,
  "directtrack-marketing": Route,
  "marketing-consulting": Compass,
  "direct-mail": Mail,
  "social-media-marketing": Share2,
  "retention-marketing": Repeat,
  "digital-marketing": Globe,
  "boost-days": Rocket,
};

const serviceIndex = services.map((service) => ({
  ...service,
  included: getServiceDetail(service.slug)?.included ?? [],
  icon: serviceIcons[service.slug] ?? Compass,
}));

const homeVipService = serviceIndex.find((service) => service.featured) ?? serviceIndex[0];
const homeDirectTrackService =
  serviceIndex.find((service) => service.slug === "directtrack-marketing") ?? serviceIndex[1];
const homeFocusedServices = serviceIndex.filter(
  (service) => service.slug !== homeVipService.slug && service.slug !== homeDirectTrackService.slug,
);

const features = [
  {
    icon: Target,
    animation: "target",
    color: "var(--key-blue)",
    title: "Shop-specific strategy",
    copy: "We start with proven auto-repair formulas, then adjust the plan around your market, capacity, goals, and customer mix.",
  },
  {
    icon: Zap,
    animation: "zap",
    color: "var(--green)",
    title: "Weekly execution",
    copy: "We don't just consult. We run the direct mail, ads, GBP, reviews, and CRM every week — you approve, we ship.",
  },
  {
    icon: BarChart3,
    animation: "chart",
    color: "var(--navy)",
    title: "Honest reporting",
    copy: "Monthly reports that tie every dollar to calls, cars, and revenue. Real accountability, no vanity metrics.",
  },
];

const opportunityCards = [
  {
    label: "Doing it all alone",
    title: "Your time becomes the hidden marketing budget.",
    cost: "You chase vendors, review reports, approve details, and solve marketing problems instead of the bigger shop problems only you can solve.",
    points: ["Vendor follow-up", "Scattered reports", "Time you never get back"],
  },
  {
    label: "Turnkey Marketing Leadership",
    title: "One team owns the whole strategy.",
    cost: "We bring the playbook, coordinate the work, and make the next move clear without making you become a marketing expert.",
    points: ["Vendors coordinated", "Reports with next moves", "Campaigns that fit your growth"],
    featured: true,
  },
] as const;

const insightPosts = resourcePosts.slice(0, 3);

const faqItems = [
  { q: "What is the best marketing strategy for an auto repair shop?", a: "The best strategy is a coordinated plan that matches your market, capacity, customer mix, and budget. For most shops, that means Google visibility, reviews, paid search, retention, direct mail, and reporting working together instead of as separate vendor tasks." },
  { q: "How do I get more customers for my auto repair shop?", a: "Start by deciding which customers and jobs you actually want more of. Then connect search, Google Business Profile, reviews, offers, follow-up, and call handling so demand turns into booked appointments." },
  { q: "How can my auto repair shop show up higher on Google Maps?", a: "Google Maps visibility usually improves when your profile, reviews, photos, location signals, website, and local relevance are stronger. No agency can guarantee rankings, but complete shop information, steady review activity, accurate listings, and useful local content give Google clearer trust signals." },
  { q: "Are Google Ads worth it for auto repair shops?", a: "Google Ads can be worth it when campaigns are tied to profitable services, clear geography, call handling, and appointment quality. If ads are only judged by clicks or cheap leads, they can spend money without filling the bays with the right cars." },
  { q: "Does direct mail still work for auto repair shops?", a: "Direct mail can still work when the list, offer, timing, and follow-up are precise. It is strongest for local radius campaigns, second-location growth, customer reactivation, and dense markets where the shop needs a physical reminder." },
  { q: "How do I know if my auto repair marketing is actually working?", a: "Marketing is working when it creates the right calls, booked appointments, returning customers, and customer mix at a cost the shop can defend. The report should explain what to keep, what to fix, what to stop spending on, and what to run next." },
  { q: "What should an auto repair shop track besides leads?", a: "Track calls, booked appointments, close rate, repair order quality, returning customers, source mix, review activity, and capacity. Lead volume by itself can hide whether marketing is helping the shop or just making the front counter busier." },
  { q: "What if I am getting calls but not enough booked appointments?", a: "That usually means the issue is between demand and the schedule, not just more marketing. Call handling, advisor scripts, offer fit, service mix, hours, and follow-up all affect whether a call becomes a car in the bay." },
  { q: "How do I bring back inactive auto repair customers?", a: "Use retention and reactivation campaigns that speak to known customers based on timing, service history, and ownership cycles. Email, SMS, direct mail, and service reminders work best when they are coordinated instead of sent as one-off blasts." },
  { q: "What if my shop does not need more cars right now?", a: "Then marketing should shift from more volume to better control. The plan can focus on retention, higher-fit work, customer quality, reputation, future demand timing, and protecting spend until capacity opens up." },
  { q: "Should I keep my current marketing vendors or replace them?", a: "Keep vendors that are producing clear value and make them part of one accountable plan. Turnkey helps shop owners see what to keep, what to cut, and what needs tighter coordination so the owner is not managing every moving part." },
  { q: "How long does auto repair marketing take to work?", a: "Some cleanup and campaign fixes can show early signals quickly, but dependable growth usually takes months. A practical first 90-120 days should clarify budget, fix tracking, clean up vendors, launch priority campaigns, and set the next moves." },
];

const mobileFaqPreviewCount = 6;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="Turnkey Marketing — Marketing that knows your auto repair shop"
  description="The auto-repair-specific marketing team that owns the plan, manages the pieces, and helps shops get more calls, more cars, and more revenue."
  path="/"
  schema={faqSchema}
>
  <section class="relative overflow-hidden bg-white">
    <div class="container-page pt-6 md:pt-10 pb-6 md:pb-8 relative">
      <div class="grid min-w-0 gap-10 lg:grid-cols-12 lg:gap-8 xl:gap-12 items-center lg:min-h-[72vh]">
        <div class="min-w-0 lg:col-span-7">
          <h1
            class="hero-heading display-1 max-w-full"
          >
            <span class="text-charcoal">Auto repair <span class="block sm:inline">marketing</span></span>
            <span
              class="hero-heading-phrase text-[var(--key-blue)]"
              data-hero-phrase
              data-phrases={JSON.stringify(heroPhrases)}
            >
              <span data-hero-phrase-text>{heroPhrases[0]}</span><span data-hero-cursor aria-hidden="true">|</span>
            </span>
          </h1>

          <p class="mt-6 max-w-[32ch] text-lg leading-relaxed text-charcoal/65 md:mt-8 md:max-w-[46ch] md:text-xl">
            Know what to keep, fix, stop funding, and run next. Then Turnkey
            owns the moving pieces while you stay focused on the shop.
          </p>

          <div class="mt-8 flex flex-col items-stretch gap-4 sm:flex-row sm:items-center md:mt-10 md:gap-6">
            <a
              href={CONSULTATION_URL}
              class="btn-primary w-full !px-7 !py-4 sm:w-auto"
              data-track-event="consultation_cta_click"
              data-track-placement="hero_primary"
            >
              Schedule a Consultation
            </a>
            <a
              href="/services"
              class="inline-flex items-center justify-center gap-2 py-1 text-charcoal/80 hover:text-charcoal font-medium text-[0.95rem] transition sm:justify-start"
            >
              See what we do
              <ArrowRight className="motion-arrow h-4 w-4" />
            </a>
          </div>
        </div>

        <div class="min-w-0 lg:col-span-5 relative w-full max-w-[350px] sm:max-w-[420px] xl:max-w-[470px] justify-self-center lg:justify-self-center xl:justify-self-end">
          <div
            class="relative aspect-[4/5] w-full rounded-[32px] overflow-hidden shadow-[0_34px_90px_-42px_rgba(20,22,28,0.45)]"
            style="background: linear-gradient(160deg, var(--key-blue) 0%, #2e6fa8 100%);"
          >
            <img
              src={siteMedia.hero.src}
              alt={siteMedia.hero.alt}
              width="1200"
              height="800"
              class="absolute inset-0 h-full w-full object-cover"
              style={`object-position: ${siteMedia.hero.position};`}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>

          <div class="floaty absolute -left-2 top-12 min-w-[168px] px-4 py-3 md:-left-5 md:top-20 md:min-w-[190px] md:px-5 md:py-4 card-float">
            <div class="text-[11px] text-charcoal/60 mb-1">Booked calls</div>
            <div class="flex items-baseline gap-2">
              <div class="font-display text-2xl font-semibold text-charcoal leading-none">
                +38%
              </div>
              <div class="text-xs font-medium" style="color: var(--green);">
                ↑ this month
              </div>
            </div>
          </div>

          <div class="floaty-delay absolute -right-2 bottom-16 min-w-[176px] px-4 py-3 md:-right-5 md:bottom-32 md:min-w-[200px] md:px-5 md:py-4 card-float">
            <div class="flex items-center gap-2 text-[11px] text-charcoal/60 mb-1.5">
              <div class="flex text-[var(--green)]">
                {[0, 1, 2, 3, 4].map(() => (
                  <Star className="h-3 w-3" fill="currentColor" />
                ))}
              </div>
              <span class="hidden sm:inline">5.0 Google rating · 300+ shops</span>
              <span class="sm:hidden">5.0 Google rating</span>
            </div>
            <div class="font-display text-sm font-semibold text-charcoal leading-tight">
              "They just know our shop."
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="logo-cloud-section bg-white pt-4 pb-8 md:pt-6 md:pb-12">
    <div class="container-page">
      <div class="mx-auto max-w-5xl text-center">
        <h2 class="font-display mx-auto max-w-4xl text-balance text-3xl font-semibold leading-tight tracking-normal text-charcoal md:text-4xl">
          Trusted by 300+ shops and industry-leading partners
        </h2>
      </div>

      <div class="mt-6 md:hidden">
        <div class="grid grid-cols-2 gap-3">
          {mobileTrustLogos.map((logo) => (
            <div class="flex h-20 items-center justify-center overflow-hidden rounded-2xl border hairline bg-white p-2.5">
              <img
                src={logo.src}
                alt={logo.name}
                class="max-h-12 w-full object-contain"
                style={`transform: scale(${logo.scale});`}
                loading="eager"
                decoding="async"
              />
            </div>
          ))}
        </div>

        <div class="mt-5 flex items-center justify-center gap-2 text-sm font-semibold text-charcoal">
          <span class="flex text-[var(--green)]" aria-label="5 out of 5 stars">
            {[0, 1, 2, 3, 4].map(() => (
              <Star className="h-3.5 w-3.5" fill="currentColor" aria-hidden="true" />
            ))}
          </span>
          <span>5.0 on Google</span>
        </div>

        <figure class="mt-4 rounded-[24px] bg-[var(--off-white)] p-5 text-left">
          <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[var(--key-blue)]">
            {mobileTrustReview.keyword}
          </p>
          <blockquote class="mt-3 font-display text-xl font-semibold leading-snug text-charcoal">
            “{mobileTrustReview.excerpt}”
          </blockquote>
          <figcaption class="mt-5 border-t hairline pt-4 text-sm text-charcoal/60">
            <span class="font-semibold text-charcoal">{mobileTrustReview.author}</span>
            {mobileTrustReview.detail !== mobileTrustReview.author && (
              <>
                <span class="mx-2 text-charcoal/30">·</span>
                {mobileTrustReview.detail}
              </>
            )}
          </figcaption>
        </figure>
      </div>

      <div class="relative mx-auto mt-3 hidden max-w-[1160px] overflow-hidden px-2 py-2 md:block">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-white to-transparent md:w-28"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-white to-transparent md:w-28"></div>
        <div>
          {logoCloudRows.map((row, rowIndex) => (
            <div
              class:list={[
                "logo-cloud-row flex w-max items-center gap-1 hover:[animation-play-state:paused] md:gap-2",
                rowIndex === 0 ? "marquee [animation-duration:44s]" : "marquee [animation-direction:reverse] [animation-duration:52s]",
              ]}
            >
              {[...row, ...row].map((logo, index) => (
                <div class="group flex h-20 w-48 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-white px-1 py-1 md:h-24 md:w-56 md:px-2">
                  <img
                    src={logo.src}
                    alt={index < row.length ? logo.name : ""}
                    aria-hidden={index >= row.length ? "true" : "false"}
                    class="max-h-[4.5rem] w-full scale-[1.04] object-contain grayscale opacity-80 transition duration-300 group-hover:grayscale-0 group-hover:opacity-100 md:max-h-[5.5rem] md:scale-[1.08]"
                    loading="eager"
                    decoding="async"
                  />
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>

      <div class="mx-auto mt-5 hidden max-w-[1160px] overflow-hidden py-2 md:mt-7 md:block">
        <div class="mb-4 flex flex-wrap items-center justify-center gap-3 text-center">
          <span class="inline-flex items-center gap-2 rounded-full bg-[var(--green)]/15 px-4 py-2 text-sm font-semibold text-charcoal">
            <span class="flex text-[var(--green)]">
              {[0, 1, 2, 3, 4].map(() => (
                <Star className="h-3.5 w-3.5" fill="currentColor" />
              ))}
            </span>
            5.0 on Google
          </span>
          <span class="text-sm text-charcoal/60">
            Shop owners mention growth, less guesswork, and getting their time back.
          </span>
        </div>

        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-10 bg-gradient-to-r from-white to-transparent md:w-20"></div>
          <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-10 bg-gradient-to-l from-white to-transparent md:w-20"></div>
          <div class="marquee flex w-max gap-4 hover:[animation-play-state:paused] [animation-duration:58s]">
            {reviewLoop.map((review, index) => (
              <figure
                class="flex w-[300px] shrink-0 flex-col justify-between rounded-[22px] bg-[var(--off-white)] p-5 md:w-[360px]"
                aria-hidden={index >= googleReviewHighlights.length ? "true" : "false"}
              >
                <div>
                  <div class="flex text-[var(--green)]">
                    {[0, 1, 2, 3, 4].map(() => (
                      <Star className="h-3.5 w-3.5" fill="currentColor" />
                    ))}
                  </div>
                  <blockquote class="mt-4 font-display text-lg font-semibold leading-snug text-charcoal">
                    “{review.excerpt}”
                  </blockquote>
                </div>
                <figcaption class="mt-5 text-sm text-charcoal/60">
                  <span class="font-semibold text-charcoal">{review.author}</span>
                  {review.detail !== review.author && (
                    <>
                      <span class="mx-2 text-charcoal/30">·</span>
                      {review.detail}
                    </>
                  )}
                </figcaption>
              </figure>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--off-white)] py-14 md:py-24">
    <div class="container-page">
      <div>
        <p class="eyebrow flex items-center gap-3">
          <span class="h-px w-8 bg-[var(--key-blue)] md:w-10" aria-hidden="true"></span>
          Services
        </p>
        <h2 class="display-2 mt-5 text-balance text-charcoal">
          Start with one service.
          <span class="block text-[var(--key-blue)]">Or hand us the whole thing.</span>
        </h2>
      </div>

      <div class="mt-9 grid gap-5 md:mt-12 lg:grid-cols-12">
        <a
          href={`/services/${homeVipService.slug}`}
          class="vip-shader-card group relative overflow-hidden rounded-[32px] bg-[var(--navy)] p-6 text-white transition hover:-translate-y-1 md:p-9 lg:col-span-7"
          data-track-event="service_cta_click"
          data-track-slug={homeVipService.slug}
          data-track-placement="home_services"
        >
          <div class="relative">
            <div class="flex items-start justify-between gap-5">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-white/10 text-[var(--green)] md:h-12 md:w-12 md:rounded-2xl">
                <Crown className="h-6 w-6 md:h-7 md:w-7" />
              </span>
              <span class="rounded-full bg-[var(--green)] px-3 py-1 text-[10px] font-semibold uppercase tracking-widest text-charcoal">
                Full team
              </span>
            </div>

            <div class="mt-6 grid gap-6 md:mt-9 md:grid-cols-[0.95fr_1.05fr] md:items-end md:gap-8">
              <div>
                <h3 class="max-w-[11ch] font-display text-4xl font-semibold leading-tight tracking-normal md:text-5xl">
                  {homeVipService.name}
                </h3>
                <p class="mt-4 max-w-md text-base leading-relaxed text-white/72 md:mt-5 md:text-lg">
                  Strategy, execution, vendors, reporting, and next moves owned
                  by one team.
                </p>
              </div>

              <div class="grid gap-3 text-sm text-white/88">
                {homeVipService.outcomes.map((outcome, index) => (
                  <span
                    class:list={[
                      "items-center gap-2 rounded-2xl bg-white/10 px-3.5 py-2.5 md:px-4 md:py-3",
                      index > 2 ? "hidden md:flex" : "flex",
                    ]}
                  >
                    <span class="h-2 w-2 rounded-full bg-[var(--green)]"></span>
                    {outcome}
                  </span>
                ))}
              </div>
            </div>

            <span class="mt-6 inline-flex items-center gap-2 font-medium md:mt-9">
              Explore VIP Marketing Manager
              <ArrowRight className="motion-arrow h-4 w-4" />
            </span>
          </div>
        </a>

        <a
          href={`/services/${homeDirectTrackService.slug}`}
          class="group flex flex-col justify-between rounded-[32px] bg-[var(--key-blue)] p-6 text-white transition hover:-translate-y-1 hover:shadow-[0_28px_70px_-48px_rgba(20,22,28,0.35)] md:p-8 lg:col-span-5"
          data-track-event="service_cta_click"
          data-track-slug={homeDirectTrackService.slug}
          data-track-placement="home_services"
        >
          <div>
            <div class="flex items-start justify-between gap-4">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-white/15 text-white md:h-12 md:w-12 md:rounded-2xl">
                <Route className="h-5 w-5 md:h-6 md:w-6" />
              </span>
              <span class="rounded-full bg-[var(--green)] px-3 py-1 text-[10px] font-semibold uppercase tracking-widest text-charcoal">
                New
