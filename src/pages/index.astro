---
import {
  ArrowRight,
  BarChart3,
  Compass,
  Crown,
  Globe,
  Mail,
  Phone,
  Quote,
  Radar,
  Repeat,
  Share2,
  Star,
  Target,
  TrendingUp,
  Zap,
} from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CONSULTATION_URL, services } from "@/lib/services";
import { getServiceDetail } from "@/lib/service-details";
import { siteMedia } from "@/lib/site-media";
import { resourcePosts } from "@/lib/resource-posts";

const heroPhrases = [
  "that fills the right bays.",
  "that brings customers back.",
  "that proves every dollar.",
  "that gets it off your plate.",
  "built around your capacity.",
];

const shopLogos = [
  { name: "CarFix", src: "/images/logos/3.png" },
  { name: "Certified Auto Repair", src: "/images/logos/certified-logo-500-2.png" },
  { name: "Gulf Breeze Automotive", src: "/images/logos/11.png" },
  {
    name: "Thunderbird Automotive Specialists",
    src: "/images/logos/26.png",
  },
  { name: "Choisser Automotive Services", src: "/images/logos/5.png" },
  { name: "European Autoworks", src: "/images/logos/8.png" },
  { name: "Killian Auto Pros", src: "/images/logos/killian-auto-pros2.jpg" },
  { name: "Pro Automotive", src: "/images/logos/pro-auto-updated-logo-500px-200x200.png" },
  { name: "Pit Shop Auto Repair", src: "/images/logos/20.png" },
  { name: "Tommy's Hi-Tech Auto Repair", src: "/images/logos/27.png" },
  { name: "Luscious Garage", src: "/images/logos/17.png" },
  { name: "Pearson Auto", src: "/images/logos/19.png" },
  { name: "Uniquely Automotive and Diesel Repair", src: "/images/logos/30.png" },
  { name: "Viking Automotive", src: "/images/logos/31.png" },
  { name: "Village Autoworks", src: "/images/logos/32.png" },
  { name: "Central Auto Care", src: "/images/logos/4.png" },
  { name: "Prestige European Auto Repair", src: "/images/logos/Prestige-Logo-Auto-Repair-10-1.png" },
  { name: "Tech One Automotive", src: "/images/logos/tech-one-automotive-logo-square.png" },
];

const logoCloudRows = [
  shopLogos.slice(0, 9),
  shopLogos.slice(9, 18),
];

const stats = [
  { k: "300+", v: "Auto repair shops served across the U.S." },
  { k: "13+", v: "Years marketing exclusively for shop owners" },
  { k: "94%", v: "Of clients renew year over year" },
];

const testimonials = [
  {
    quote: "They take care of everything.",
    name: "Len Pritchett",
    shop: "RPM Automotive",
    location: "Prairie Du Chien, WI",
    marker: "Marketing ownership",
    image: siteMedia.clients.lenPritchett,
  },
  {
    quote: "One of the best investments I have made in my company.",
    name: "Jason Smith",
    shop: "M&M Car Care Center",
    location: "Northwest Indiana",
    marker: "Multi-store growth",
    image: siteMedia.clients.jasonSmith,
  },
  {
    quote: "We got to $300,000/month within one year at a brand new shop.",
    name: "Steve Killian",
    shop: "Killian Auto Pros",
    location: "Greenville, SC",
    marker: "Second-location ramp",
    image: siteMedia.clients.steveKillian,
  },
];

const serviceIcons: Record<string, typeof Crown> = {
  "vip-marketing-manager": Crown,
  "directtrack-marketing": Radar,
  "marketing-consulting": Compass,
  "direct-mail": Mail,
  "social-media-marketing": Share2,
  "retention-marketing": Repeat,
  "digital-marketing": Globe,
  "boost-days": Zap,
};

const serviceIndex = services.map((service) => ({
  ...service,
  included: getServiceDetail(service.slug)?.included ?? [],
  icon: serviceIcons[service.slug] ?? Compass,
}));

const features = [
  {
    icon: Target,
    color: "var(--key-blue)",
    title: "Shop-specific strategy",
    copy: "Every plan is built around your bays, your market, and your goals. No recycled templates, no cookie-cutter tactics.",
  },
  {
    icon: Zap,
    color: "var(--green)",
    title: "Weekly execution",
    copy: "We don't just consult. We run the direct mail, ads, GBP, reviews, and CRM every week — you approve, we ship.",
  },
  {
    icon: BarChart3,
    color: "var(--navy)",
    title: "Honest reporting",
    copy: "Monthly reports that tie every dollar to calls, cars, and revenue. Real accountability, no vanity metrics.",
  },
];

const opportunityCards = [
  {
    label: "Doing It All Alone",
    title: "You manage all the moving pieces",
    points: ["Vendor follow-up", "Scattered reports", "Owner time"],
  },
  {
    label: "Turnkey",
    title: "One team owns the whole strategy.",
    points: ["Vendors coordinated for you", "Reports show what to do next", "Campaigns that fit your growth"],
    featured: true,
  },
] as const;

const insightPosts = resourcePosts.slice(0, 3);

const faqItems = [
  { q: "What is the best marketing strategy for an auto repair shop?", a: "The best strategy is a coordinated plan that matches your market, capacity, customer mix, and budget. For most shops, that means Google visibility, reviews, paid search, retention, direct mail, and reporting working together instead of as separate vendor tasks." },
  { q: "How do I get more customers for my auto repair shop?", a: "Start by deciding which customers and jobs you actually want more of. Then connect search, Google Business Profile, reviews, offers, follow-up, and call handling so demand turns into booked appointments." },
  { q: "How can my auto repair shop show up higher on Google Maps?", a: "Google Maps visibility usually improves when your profile, reviews, photos, location signals, website, and local relevance are stronger. No agency can guarantee rankings, but complete shop information, steady review activity, accurate listings, and useful local content give Google clearer trust signals." },
  { q: "Are Google Ads worth it for auto repair shops?", a: "Google Ads can be worth it when campaigns are tied to profitable services, clear geography, call handling, and appointment quality. If ads are only judged by clicks or cheap leads, they can spend money without filling the bays with the right cars." },
  { q: "Does direct mail still work for auto repair shops?", a: "Direct mail can still work when the list, offer, timing, and follow-up are precise. It is strongest for local radius campaigns, second-location growth, customer reactivation, and dense markets where the shop needs a physical reminder." },
  { q: "How do I know if my auto repair marketing is actually working?", a: "Marketing is working when it creates the right calls, booked appointments, returning customers, and customer mix at a cost the shop can defend. The report should explain what to keep, what to fix, what to stop spending on, and what to run next." },
  { q: "What should an auto repair shop track besides leads?", a: "Track calls, booked appointments, close rate, repair order quality, returning customers, source mix, review activity, and capacity. Lead volume by itself can hide whether marketing is helping the shop or just making the front counter busier." },
  { q: "What if I am getting calls but not enough booked appointments?", a: "That usually means the issue is between demand and the schedule, not just more marketing. Call handling, advisor scripts, offer fit, service mix, hours, and follow-up all affect whether a call becomes a car in the bay." },
  { q: "How do I bring back inactive auto repair customers?", a: "Use retention and reactivation campaigns that speak to known customers based on timing, service history, and ownership cycles. Email, SMS, direct mail, and service reminders work best when they are coordinated instead of sent as one-off blasts." },
  { q: "What if my shop does not need more cars right now?", a: "Then marketing should shift from more volume to better control. The plan can focus on retention, higher-fit work, customer quality, reputation, future demand timing, and protecting spend until capacity opens up." },
  { q: "Should I keep my current marketing vendors or replace them?", a: "Keep vendors that are producing clear value and make them part of one accountable plan. Turnkey helps shop owners see what to keep, what to cut, and what needs tighter coordination so the owner is not managing every moving part." },
  { q: "How long does auto repair marketing take to work?", a: "Some cleanup and campaign fixes can show early signals quickly, but dependable growth usually takes months. A practical first 90-120 days should clarify budget, fix tracking, clean up vendors, launch priority campaigns, and set the next moves." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="Turnkey Marketing — Marketing that knows your auto repair shop"
  description="The auto-repair-specific marketing team that owns the plan, manages the pieces, and helps shops get more calls, more cars, and more revenue."
  path="/"
  schema={faqSchema}
>
  <section class="relative overflow-hidden bg-white">
    <div class="container-page pt-6 md:pt-10 pb-6 md:pb-8 relative">
      <div class="grid gap-10 lg:grid-cols-12 lg:gap-8 xl:gap-12 items-center lg:min-h-[72vh]">
        <div class="lg:col-span-7">
          <h1
            class="display-1 text-balance"
            style="font-size: clamp(2.5rem, 4.2vw, 3.5rem); line-height: 1.05;"
          >
            <span class="text-charcoal">Auto repair marketing</span>
            <br />
            <span
              class="inline-block whitespace-nowrap text-[clamp(1.4rem,5vw,3rem)] text-[var(--key-blue)]"
              data-hero-phrase
              data-phrases={JSON.stringify(heroPhrases)}
            >
              {heroPhrases[0]}
            </span>
          </h1>

          <p class="mt-6 text-lg md:mt-8 md:text-xl text-charcoal/65 max-w-[46ch] leading-relaxed">
            Know what to keep, fix, stop funding, and run next. Then Turnkey
            owns the moving pieces while you stay focused on the shop.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-5 md:mt-10 md:gap-6">
            <a
              href={CONSULTATION_URL}
              class="btn-primary !px-7 !py-4"
              data-track-event="consultation_cta_click"
              data-track-placement="hero_primary"
            >
              Schedule a Consultation
            </a>
            <a
              href="/services"
              class="inline-flex items-center gap-2 text-charcoal/80 hover:text-charcoal font-medium text-[0.95rem] transition"
            >
              See what we do
              <ArrowRight className="h-4 w-4" />
            </a>
          </div>
        </div>

        <div class="lg:col-span-5 relative w-full max-w-[420px] xl:max-w-[470px] justify-self-center lg:justify-self-center xl:justify-self-end">
          <div
            class="relative aspect-[4/5] w-full rounded-[32px] overflow-hidden shadow-[0_34px_90px_-42px_rgba(20,22,28,0.45)]"
            style="background: linear-gradient(160deg, var(--key-blue) 0%, #2e6fa8 100%);"
          >
            <img
              src={siteMedia.hero.src}
              alt={siteMedia.hero.alt}
              width="1200"
              height="800"
              class="absolute inset-0 h-full w-full object-cover"
              style={`object-position: ${siteMedia.hero.position};`}
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>

          <div class="floaty absolute -left-3 md:-left-5 top-14 md:top-20 card-float px-5 py-4 min-w-[190px]">
            <div class="text-[11px] text-charcoal/60 mb-1">Booked calls</div>
            <div class="flex items-baseline gap-2">
              <div class="font-display text-2xl font-semibold text-charcoal leading-none">
                +38%
              </div>
              <div class="text-xs font-medium" style="color: var(--green);">
                ↑ this month
              </div>
            </div>
          </div>

          <div class="floaty-delay absolute -right-3 md:-right-5 bottom-24 md:bottom-32 card-float px-5 py-4 min-w-[200px]">
            <div class="flex items-center gap-2 text-[11px] text-charcoal/60 mb-1.5">
              <div class="flex text-[var(--green)]">
                {[0, 1, 2, 3, 4].map(() => (
                  <Star className="h-3 w-3" fill="currentColor" />
                ))}
              </div>
              <span>4.9 · 300+ shops</span>
            </div>
            <div class="font-display text-sm font-semibold text-charcoal leading-tight">
              "They just know our shop."
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="logo-cloud-section bg-white pt-4 pb-8 md:pt-6 md:pb-12">
    <div class="container-page">
      <div class="mx-auto max-w-5xl text-center">
        <h2 class="font-display mx-auto max-w-4xl text-balance text-3xl font-semibold leading-tight tracking-normal text-charcoal md:text-4xl">
          Trusted by 300+ shops and industry-leading partners
        </h2>
      </div>

      <div class="relative mx-auto mt-3 max-w-[1160px] overflow-hidden px-2 py-2">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 bg-gradient-to-r from-white to-transparent md:w-28"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 bg-gradient-to-l from-white to-transparent md:w-28"></div>
        <div>
          {logoCloudRows.map((row, rowIndex) => (
            <div
              class:list={[
                "logo-cloud-row flex w-max items-center gap-4 hover:[animation-play-state:paused] md:gap-5",
                rowIndex === 0 ? "marquee [animation-duration:44s]" : "marquee [animation-direction:reverse] [animation-duration:52s]",
              ]}
            >
              {[...row, ...row].map((logo, index) => (
                <div class="group flex h-20 w-60 shrink-0 items-center justify-center rounded-2xl bg-white px-3 py-1 md:h-24 md:w-72 md:px-4">
                  <img
                    src={logo.src}
                    alt={index < row.length ? logo.name : ""}
                    aria-hidden={index >= row.length ? "true" : "false"}
                    class="max-h-[4.5rem] w-full object-contain grayscale opacity-75 transition duration-300 group-hover:grayscale-0 group-hover:opacity-100 md:max-h-[5.5rem]"
                    loading="eager"
                    decoding="async"
                  />
                </div>
              ))}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--off-white)] py-16 md:py-24">
    <div class="container-page">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div>
          <p class="eyebrow" style="color: var(--key-blue);">Services</p>
          <h2 class="display-2 mt-4 text-balance">
            Marketing services built around your shop.
          </h2>
        </div>
        <p class="max-w-2xl text-lg leading-relaxed text-charcoal/65 lg:justify-self-end">
          Start with the full VIP program, or use a focused service where your
          shop needs momentum first.
        </p>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-2 md:mt-12 lg:grid-cols-4 lg:gap-5">
        {serviceIndex.map((service) => {
          const Icon = service.icon;
          const featured = Boolean(service.featured);
          return (
            <a
              href={`/services/${service.slug}`}
              class:list={[
                "group flex h-full flex-col rounded-[24px] p-6 transition duration-300 hover:-translate-y-1",
                featured
                  ? "bg-[var(--navy)] text-white hover:shadow-[0_28px_70px_-40px_rgba(35,46,102,0.75)]"
                  : "bg-white text-charcoal hover:shadow-[0_28px_70px_-48px_rgba(20,22,28,0.35)]",
              ]}
              data-track-event="service_cta_click"
              data-track-slug={service.slug}
              data-track-placement="home_services"
            >
              <div class="flex items-start justify-between gap-3">
                <span
                  class:list={[
                    "inline-flex h-11 w-11 items-center justify-center rounded-xl",
                    featured
                      ? "bg-white/10 text-[var(--green)]"
                      : "bg-[var(--key-blue-soft)] text-[var(--navy)]",
                  ]}
                >
                  <Icon className="h-5 w-5" />
                </span>
                {(featured || service.isNew) && (
                  <span
                    class="rounded-full px-2.5 py-1 text-[9px] font-semibold uppercase tracking-widest"
                    style="background: var(--green); color: var(--charcoal);"
                  >
                    {featured ? "Flagship" : "New"}
                  </span>
                )}
              </div>

              <h3 class="mt-5 font-display text-xl font-semibold leading-snug">
                {service.name}
              </h3>

              <ul
                class:list={[
                  "mt-4 space-y-2 text-sm leading-relaxed",
                  featured ? "text-white/75" : "text-charcoal/60",
                ]}
              >
                {service.included.slice(0, 4).map((item) => (
                  <li class="flex items-start gap-2.5">
                    <span
                      class="mt-[0.45rem] h-1.5 w-1.5 flex-none rounded-full"
                      style={`background: ${featured ? "var(--green)" : "var(--key-blue)"};`}
                    ></span>
                    {item}
                  </li>
                ))}
                {service.included.length > 4 && (
                  <li
                    class:list={[
                      "pl-4 text-xs font-medium",
                      featured ? "text-white/55" : "text-charcoal/45",
                    ]}
                  >
                    + {service.included.length - 4} more
                  </li>
                )}
              </ul>

              <span
                class:list={[
                  "mt-auto inline-flex items-center gap-1.5 pt-6 text-sm font-medium transition",
                  featured
                    ? "text-white"
                    : "text-charcoal group-hover:text-[var(--navy)]",
                ]}
              >
                View service
                <ArrowRight className="h-4 w-4 transition group-hover:translate-x-1" />
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="pt-12 pb-20 md:pt-24 md:pb-32">
    <div class="container-page">
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="display-2 text-balance">
          Everything you need to <span class="text-charcoal/45">grow your shop.</span>
        </h2>
        <p class="mt-6 text-charcoal/65 text-lg leading-relaxed">
          From strategy to execution, we run the marketing playbook that has
          filled bays for hundreds of shops across the country — while their
          owners run the shop.
        </p>
      </div>

      <div class="mt-10 grid gap-8 md:mt-16 md:grid-cols-3 md:divide-x hairline">
        {stats.map((stat) => (
          <div class="text-center px-6">
            <div class="font-display text-5xl md:text-7xl font-semibold text-charcoal tracking-tight">
              {stat.k}
            </div>
            <p class="mt-4 text-charcoal/60 max-w-[24ch] mx-auto leading-relaxed">
              {stat.v}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-24 md:pb-32">
    <div class="container-page">
      <div
        class="rounded-[32px] overflow-hidden grid lg:grid-cols-2 gap-10 p-10 md:p-16 relative"
        style="background: var(--charcoal); color: #fff;"
      >
        <div class="relative">
          <h3 class="display-2 leading-tight text-white text-balance">
            Own the plan.<br />
            <span class="text-white/50">Run every channel.</span>
          </h3>
          <p class="mt-6 text-white/70 text-lg max-w-md leading-relaxed">
            Not more homework. More ownership. We coordinate vendors, campaigns,
            reporting, and next steps without making you manage every marketing
            decision.
          </p>
          <div class="mt-10">
            <a
              href={CONSULTATION_URL}
              class="inline-flex items-center gap-2 rounded-full px-6 py-3.5 font-medium text-sm bg-white text-charcoal hover:bg-white/90 transition"
              data-track-event="consultation_cta_click"
              data-track-placement="launch_section"
            >
              Talk through the plan
            </a>
          </div>
        </div>

        <div class="relative mx-auto mt-4 w-full max-w-[420px] lg:mx-0 lg:ml-auto lg:mt-0 lg:w-[65%] lg:max-w-none">
          <div
            class="aspect-[3/4] w-full overflow-hidden rounded-[24px]"
            style="background: linear-gradient(160deg, var(--key-blue) 0%, var(--navy) 100%);"
          >
            <img
              src={siteMedia.shops.thunderbirdTeam.src}
              alt={siteMedia.shops.thunderbirdTeam.alt}
              loading="lazy"
              decoding="async"
              width="1200"
              height="900"
              class="absolute inset-0 w-full h-full object-cover"
              style={`object-position: ${siteMedia.shops.thunderbirdTeam.position};`}
            />
          </div>
          <div class="absolute -left-2 top-4 card-float px-3.5 py-3 md:-left-4 md:min-w-[200px] md:px-5 md:py-4 lg:top-8">
            <div class="flex items-center gap-2 text-[10px] text-charcoal/60 md:text-[11px]">
              <span
                class="inline-flex h-5 w-5 items-center justify-center rounded-md text-[var(--key-blue)] md:h-6 md:w-6"
                style="background: var(--key-blue-soft);"
              >
                <TrendingUp className="h-3 w-3" />
              </span>
              Monthly revenue
            </div>
            <div class="mt-2 flex items-center gap-2.5 md:mt-3 md:gap-3">
              <svg viewBox="0 0 40 40" class="h-10 w-10 md:h-14 md:w-14">
                <circle cx="20" cy="20" r="16" fill="none" stroke="#E7E5DF" stroke-width="5"></circle>
                <circle
                  cx="20"
                  cy="20"
                  r="16"
                  fill="none"
                  stroke="var(--navy)"
                  stroke-width="5"
                  stroke-dasharray="100.5"
                  stroke-dashoffset="28"
                  transform="rotate(-90 20 20)"
                  stroke-linecap="round"
                ></circle>
              </svg>
              <div>
                <div class="text-[10px] text-charcoal/60">Revenue</div>
                <div class="font-display text-base font-semibold text-charcoal md:text-lg">$182k</div>
              </div>
            </div>
          </div>
          <div class="absolute -right-2 bottom-4 card-float w-[172px] px-3.5 py-3 md:-right-4 md:w-auto md:min-w-[220px] md:px-4 lg:bottom-6">
            <div class="flex items-center justify-between text-[10px] text-charcoal/60">
              <span>Channel mix</span>
              <span style="color: var(--green);">+1.4% MoM</span>
            </div>
            <div class="mt-2 flex gap-2 text-[10px] text-charcoal/70">
              <span class="inline-flex items-center gap-1">
                <span class="h-2 w-2 rounded-sm" style="background: var(--navy);"></span>
                Direct mail
              </span>
              <span class="inline-flex items-center gap-1">
                <span class="h-2 w-2 rounded-sm" style="background: var(--key-blue);"></span>
                Digital
              </span>
            </div>
            <div class="mt-2 flex h-9 items-end gap-1 md:h-12">
              {[[50, 30], [60, 40], [45, 35], [70, 45], [55, 60], [80, 55]].map(([a, b]) => (
                <div class="flex-1 h-full flex gap-0.5 items-end">
                  <div class="flex-1 rounded-sm" style={`height: ${a}%; background: var(--navy);`}></div>
                  <div class="flex-1 rounded-sm" style={`height: ${b}%; background: var(--key-blue);`}></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24 md:pb-32">
    <div class="container-page">
      <div class="text-center max-w-3xl mx-auto">
        <p class="eyebrow" style="color: var(--key-blue);">Client proof</p>
        <h2 class="display-2 mt-4 text-balance">
          Shop owners say <span class="text-charcoal/45">it best.</span>
        </h2>
        <p class="mt-6 text-charcoal/65 text-lg leading-relaxed">
          Real repair shop owners talking about what changes when Turnkey owns
          the plan, the follow-through, and the next move.
        </p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-3">
        {testimonials.map((testimonial) => (
          <figure
            class="rounded-[28px] p-8 flex flex-col min-h-[360px] relative overflow-hidden"
            style="background: var(--off-white);"
          >
            <Quote className="absolute right-7 top-7 h-10 w-10 text-[var(--key-blue)] opacity-30" aria-hidden="true" />
            <p class="text-xs uppercase tracking-widest text-[var(--key-blue)]">
              {testimonial.marker}
