---
import { ArrowRight, ArrowUpRight, Check } from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CONSULTATION_URL, services, type Service } from "@/lib/services";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;
const related = services.filter((item) => item.slug !== service.slug).slice(0, 3);

const servicePath = `/services/${service.slug}`;
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.name,
  description: service.summary,
  provider: {
    "@type": "Organization",
    name: "Turnkey Marketing",
    url: "https://turnkeyautomarketing.com",
  },
  areaServed: "United States",
  serviceType: "Auto repair marketing",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Services",
      item: "https://turnkeyautomarketing.com/services",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: service.name,
      item: `https://turnkeyautomarketing.com${servicePath}`,
    },
  ],
};
---

<BaseLayout
  title={`${service.name} — Turnkey Marketing`}
  description={service.summary}
  path={servicePath}
  ogTitle={`${service.name} — Turnkey Marketing`}
  ogType="article"
  schema={[serviceSchema, breadcrumbSchema]}
>
  <section class="border-b hairline">
    <div class="container-page pt-16 md:pt-24 pb-20">
      <a href="/services" class="text-sm text-muted-foreground hover:text-charcoal">
        ← All services
      </a>
      <div class="mt-6 grid gap-12 lg:grid-cols-12 items-end">
        <div class="lg:col-span-8">
          <p class="eyebrow">
            {service.featured ? "Flagship offer" : "Service"}
          </p>
          <h1 class="display-1 mt-6 text-balance">{service.name}</h1>
          <p class="mt-6 text-xl text-muted-foreground max-w-2xl leading-relaxed">
            {service.tagline}
          </p>
        </div>
        <div class="lg:col-span-4">
          <a
            href={CONSULTATION_URL}
            target="_blank"
            rel="noopener"
            class="btn-primary w-full"
            data-track-event="service_cta_click"
            data-track-slug={service.slug}
            data-track-placement="service_hero"
          >
            Talk about {service.name} <ArrowRight className="h-4 w-4" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-20 grid gap-16 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <p class="eyebrow">Overview</p>
      <h2 class="display-3 mt-4 text-balance">What you actually get.</h2>
    </div>
    <div class="lg:col-span-7">
      <p class="text-lg text-muted-foreground leading-relaxed">{service.summary}</p>
      <ul class="mt-10 grid gap-4">
        {service.outcomes.map((outcome) => (
          <li class="flex items-start gap-4 border-b hairline pb-4">
            <span
              class="mt-1 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full"
              style="background: var(--green);"
            >
              <Check className="h-3 w-3 text-charcoal" />
            </span>
            <span class="text-charcoal">{outcome}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section style="background: var(--off-white);">
    <div class="container-page py-20">
      <p class="eyebrow">How we work</p>
      <div class="mt-8 grid gap-px md:grid-cols-3 bg-[var(--hairline)] rounded-2xl overflow-hidden">
        {[
          { n: "01", t: "Learn the shop", d: "Interviews, audits, and a real look at your goals and market." },
          { n: "02", t: "Build the plan", d: "Strategy first. Then the tactics that actually fit your shop." },
          { n: "03", t: "Run it, report it", d: "Weekly execution and honest monthly reporting you can act on." },
        ].map((step) => (
          <div class="bg-white p-8">
            <p class="text-xs tracking-widest text-muted-foreground">{step.n}</p>
            <p class="font-display text-xl mt-4 text-charcoal">{step.t}</p>
            <p class="mt-2 text-muted-foreground">{step.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-20">
    <div class="flex items-end justify-between flex-wrap gap-6">
      <h2 class="display-3">Explore related services</h2>
      <a href="/services" class="btn-ghost">All services →</a>
    </div>
    <div class="mt-10 border-t hairline">
      {related.map((item) => (
        <a
          href={`/services/${item.slug}`}
          class="group grid grid-cols-12 gap-6 border-b hairline py-6 items-baseline hover:bg-[var(--off-white)] transition px-2 -mx-2 rounded-md"
        >
          <span class="col-span-11 md:col-span-4 font-display text-2xl text-charcoal">{item.name}</span>
          <span class="col-span-11 md:col-span-7 text-muted-foreground col-start-2 md:col-start-auto">{item.tagline}</span>
          <span class="col-span-1 justify-self-end"><ArrowUpRight className="h-5 w-5" /></span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
