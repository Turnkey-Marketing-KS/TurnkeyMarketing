---
import {
  ArrowRight,
  BarChart3,
  Calendar,
  Check,
  ChevronRight,
  ClipboardList,
  Compass,
  DollarSign,
  Facebook,
  FileText,
  Globe,
  Heart,
  Instagram,
  Layers,
  Mail,
  MapPin,
  Megaphone,
  MessageSquare,
  Palette,
  PenLine,
  Phone,
  RefreshCw,
  Repeat,
  Search,
  Share2,
  Star,
  Target,
  TrendingUp,
  Tv,
  UserRound,
  Users,
  X,
  Zap,
} from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CONSULTATION_URL, services, type Service } from "@/lib/services";
import { getServiceDetail } from "@/lib/service-details";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;
const detail = getServiceDetail(service.slug);
const servicePath = `/services/${service.slug}`;
const accent = detail.accent ?? "blue";
const accentColor = accent === "green" ? "var(--green)" : "var(--key-blue)";
const hero = detail.hero;
const shortName = service.shortName ?? service.name;
const serviceIndex = services.findIndex((s) => s.slug === service.slug);
const serviceTitle =
  service.slug === "vip-marketing-manager"
    ? "VIP Marketing Manager for Auto Repair Shops"
    : service.slug === "directtrack-marketing"
      ? "DirectTrack Marketing for Auto Repair Shops"
      : `${service.name} for Auto Repair Shops`;

const deliverableIcons: Record<string, typeof Check> = {
  layers: Layers,
  user: UserRound,
  users: Users,
  share: Share2,
  palette: Palette,
  pen: PenLine,
  clipboard: ClipboardList,
  calendar: Calendar,
  search: Search,
  compass: Compass,
  trending: TrendingUp,
  mail: Mail,
  tv: Tv,
  "map-pin": MapPin,
  chart: BarChart3,
  dollar: DollarSign,
  target: Target,
  repeat: Repeat,
  facebook: Facebook,
  instagram: Instagram,
  megaphone: Megaphone,
  message: MessageSquare,
  heart: Heart,
  refresh: RefreshCw,
  star: Star,
  globe: Globe,
  zap: Zap,
  phone: Phone,
  file: FileText,
};

const relatedServices = detail.pairsWith
  .map((slug) => services.find((s) => s.slug === slug))
  .filter((s): s is Service => Boolean(s));

const trustStats = [
  { value: "300+", label: "Auto repair shops served across the U.S." },
  { value: "13+", label: "Years marketing exclusively for shop owners" },
  { value: "5.0★", label: "Google rating from shop owners and clients" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.name,
  description: service.summary,
  provider: {
    "@type": "Organization",
    name: "Turnkey Marketing",
    url: "https://turnkeyautomarketing.com",
  },
  areaServed: "United States",
  serviceType: "Auto repair marketing",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Services",
      item: "https://turnkeyautomarketing.com/services",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: service.name,
      item: `https://turnkeyautomarketing.com${servicePath}`,
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: detail.faqs.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title={`${serviceTitle} — Turnkey Marketing`}
  description={service.summary}
  path={servicePath}
  ogTitle={`${serviceTitle} — Turnkey Marketing`}
  ogType="article"
  ogImage={detail.image.src}
  schema={[serviceSchema, breadcrumbSchema, faqSchema]}
>
  <section class="relative bg-white">
    <div class="container-page pb-16 pt-8 md:pb-20 md:pt-10">
      <div class="flex items-center justify-between" data-reveal>
        <nav aria-label="Breadcrumb" class="flex items-center gap-1.5 text-sm text-muted-foreground">
          <a href="/services" class="transition hover:text-charcoal">Services</a>
          <ChevronRight className="h-3.5 w-3.5 text-charcoal/35" />
          <span class="font-medium text-charcoal">{service.name}</span>
        </nav>
        <span class="hidden text-sm font-medium tabular-nums tracking-[0.16em] text-charcoal/35 sm:block">
          {String(serviceIndex + 1).padStart(2, "0")} / {String(services.length).padStart(2, "0")}
        </span>
      </div>

      <div class="mt-14 md:mt-20 lg:mt-24">
        <p class="eyebrow flex items-center gap-3" data-reveal style="--reveal-delay: 60ms;">
          <span class="h-px w-8 md:w-10" style={`background: ${accentColor};`} aria-hidden="true"
          ></span>
          <span><span class="hidden sm:inline">{service.name} · </span>{hero.badge}</span>
        </p>

        <h1
          class="mt-7 max-w-[22ch] font-display font-semibold text-balance text-charcoal"
          style="font-size: clamp(2.6rem, 7.2vw, 5.5rem); line-height: 1.01; letter-spacing: -0.045em; --reveal-delay: 120ms;"
          data-reveal
        >
          {hero.headline}
          <span class="block text-[var(--key-blue)]">{hero.headlineAccent}</span>
        </h1>
      </div>

      <div
        class="mt-12 grid gap-8 md:mt-16 lg:grid-cols-12 lg:items-end lg:gap-10"
        data-reveal
        style="--reveal-delay: 200ms;"
      >
        <p class="max-w-[46ch] text-lg leading-relaxed text-charcoal/60 md:text-xl lg:col-span-7">
          {hero.subhead}
        </p>
        <div
          class="flex flex-col items-start gap-5 sm:flex-row sm:items-center lg:col-span-5 lg:justify-end"
        >
          <a
            href={CONSULTATION_URL}
            class="btn-primary whitespace-nowrap !px-7 !py-4"
            data-track-event="consultation_cta_click"
            data-track-slug={service.slug}
            data-track-placement="service_hero"
          >
            Schedule a Consultation
            <ArrowRight className="h-4 w-4" />
          </a>
          <a
            href="#service-includes"
            class="group inline-flex items-center gap-2 whitespace-nowrap py-1 font-medium text-charcoal/80 transition hover:text-charcoal"
          >
            See what's included
            <ArrowRight className="motion-arrow h-4 w-4" />
          </a>
        </div>
      </div>

      <div
        class="mt-16 grid gap-8 border-t border-[var(--hairline)] pt-8 sm:grid-cols-3 md:mt-24 md:gap-12 md:pt-10"
        data-reveal
        style="--reveal-delay: 260ms;"
      >
        {hero.stats.map((stat) => (
          <div>
            <p class="font-display text-lg font-semibold tracking-tight text-charcoal md:text-xl">
              {stat.value}
            </p>
            <p class="mt-1.5 max-w-[36ch] text-sm leading-relaxed text-muted-foreground">
              {stat.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--off-white)] py-14 md:py-24">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <p class="eyebrow" style={`color: ${accentColor};`}>Sound familiar?</p>
          <h2 class="display-3 mt-4 text-balance text-charcoal">
            You didn't open a shop to spend your nights doing marketing.
          </h2>
          <p class="mt-5 leading-relaxed text-charcoal/65">
            These are the problems shop owners bring us right before they hand this work over.
          </p>
        </div>

        <div class="lg:col-span-7">
          <div class="space-y-3">
            {detail.pains.map((pain) => (
              <div class="flex items-start gap-4 rounded-2xl bg-white p-5 md:p-6">
                <span class="mt-0.5 inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-[var(--off-white)]">
                  <X className="h-3.5 w-3.5 text-charcoal/55" />
                </span>
                <p class="leading-relaxed text-charcoal/75 md:text-lg">{pain}</p>
              </div>
            ))}

            <div class="flex items-start gap-4 rounded-2xl bg-[var(--navy)] p-5 text-white md:p-6">
              <span
                class="mt-0.5 inline-flex h-7 w-7 flex-none items-center justify-center rounded-full"
                style={`background: ${accentColor};`}
              >
                <Check className="h-3.5 w-3.5 text-white" />
              </span>
              <div>
                <p class="font-display text-lg font-semibold leading-tight">
                  Where {shortName} fits
                </p>
                <p class="mt-1.5 leading-relaxed text-white/75">{detail.bestFor}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="service-includes" class="bg-white py-14 md:py-24">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-28">
            <p class="eyebrow" style={`color: ${accentColor};`}>What's included</p>
            <h2 class="display-3 mt-4 text-balance text-charcoal">
              Everything it takes to make this work. Handled.
            </h2>
            <p class="mt-5 leading-relaxed text-charcoal/65">{service.summary}</p>
            <a
              href={CONSULTATION_URL}
              class="btn-primary mt-7"
              data-track-event="consultation_cta_click"
              data-track-slug={service.slug}
              data-track-placement="service_includes"
            >
              Schedule a Consultation
              <ArrowRight className="h-4 w-4" />
            </a>
          </div>
        </div>

        <div class="lg:col-span-8">
          <div class="grid gap-4 sm:grid-cols-2">
            {detail.deliverables.map((item) => {
              const Icon = deliverableIcons[item.icon] ?? Check;
              return (
                <div class="motion-card rounded-[24px] border border-[var(--hairline)] bg-[var(--cream)] p-6 md:p-7">
                  <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-[var(--navy)]">
                    <Icon className="h-5 w-5 text-white" />
                  </span>
                  <p class="mt-5 font-display text-xl font-semibold leading-tight tracking-normal text-charcoal">
                    {item.title}
                  </p>
                  <p class="mt-2 leading-relaxed text-muted-foreground">{item.description}</p>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--charcoal)] py-14 text-white md:py-24">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="eyebrow" style={`color: ${accentColor};`}>How it works</p>
        <h2 class="display-3 mt-4 text-balance text-white">
          Simple on purpose. You run the shop — we run the plan.
        </h2>
      </div>

      <div class="mt-12 grid gap-10 md:grid-cols-3 md:gap-8 lg:gap-12">
        {detail.process.map((step, index) => (
          <div class="border-t border-white/15 pt-7">
            <span
              class="font-display text-sm font-semibold tracking-[0.18em]"
              style={`color: ${accentColor};`}
            >
              {String(index + 1).padStart(2, "0")}
            </span>
            <p class="mt-4 font-display text-2xl font-semibold leading-tight tracking-normal text-white">
              {step.title}
            </p>
            <p class="mt-3 leading-relaxed text-white/65">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-14 md:py-24">
    <div class="container-page">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-16">
        <div class="lg:col-span-7">
          <div class="flex items-center gap-1" aria-hidden="true">
            {[0, 1, 2, 3, 4].map(() => (
              <Star className="h-5 w-5 fill-[var(--green)] text-[var(--green)]" />
            ))}
          </div>
          <blockquote class="mt-6 font-display text-2xl font-semibold leading-snug tracking-tight text-charcoal md:text-4xl md:leading-[1.18]">
            “{detail.testimonial.quote}”
          </blockquote>
          <p class="mt-7 font-semibold text-charcoal">{detail.testimonial.name}</p>
          {detail.testimonial.detail !== detail.testimonial.name && (
            <p class="mt-1 text-sm text-muted-foreground">{detail.testimonial.detail}</p>
          )}
        </div>

        <div class="lg:col-span-5">
          <div class="rounded-[28px] bg-[var(--off-white)] p-7 md:p-9">
            <div class="space-y-6">
              {trustStats.map((stat, index) => (
                <div class:list={[index > 0 && "border-t border-[var(--hairline)] pt-6"]}>
                  <p class="font-display text-3xl font-semibold tracking-tight text-charcoal">
                    {stat.value}
                  </p>
                  <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{stat.label}</p>
                </div>
              ))}
            </div>
            <a
              href="/results"
              class="group mt-8 inline-flex items-center gap-2 font-medium text-charcoal"
            >
              See real shop results
              <ArrowRight className="motion-arrow h-4 w-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--off-white)] py-14 md:py-24">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
        <div class="lg:col-span-5">
          <p class="eyebrow" style={`color: ${accentColor};`}>Questions</p>
          <h2 class="display-3 mt-4 text-balance text-charcoal">
            What shop owners ask about {shortName}.
          </h2>
          <p class="mt-5 leading-relaxed text-charcoal/65">
            If your question isn't here, bring it to the call — that's what it's for.
          </p>
          <a
            href={CONSULTATION_URL}
            class="btn-ghost mt-7"
            data-track-event="consultation_cta_click"
            data-track-slug={service.slug}
            data-track-placement="service_faq"
          >
            Ask us directly
            <ArrowRight className="h-4 w-4" />
          </a>
        </div>

        <div class="space-y-3 lg:col-span-7">
          {detail.faqs.map((item, index) => (
            <details
              class="faq-item overflow-hidden rounded-2xl border hairline bg-white"
              open={index === 0}
            >
              <summary class="flex w-full cursor-pointer items-center justify-between px-5 py-4 text-left transition-colors hover:bg-[var(--cream)] md:px-6 md:py-5">
                <span class="pr-5 font-display text-base font-semibold text-charcoal md:pr-8 md:text-lg">
                  {item.q}
                </span>
                <span
                  class="inline-flex h-8 w-8 flex-none items-center justify-center rounded-full"
                  style="background: var(--off-white);"
                >
                  <span class="faq-plus">+</span>
                  <span class="faq-minus">−</span>
                </span>
              </summary>
              <div class="px-5 pb-5 leading-relaxed text-charcoal/70 md:px-6 md:pb-6">
                {item.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-14 md:py-24">
    <div class="container-page">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="eyebrow" style={`color: ${accentColor};`}>Pairs well with</p>
          <h2 class="display-3 mt-4 text-balance text-charcoal">Shops rarely run just one piece.</h2>
        </div>
        <a href="/services" class="group inline-flex items-center gap-2 pb-1 font-medium text-charcoal">
          All services
          <ArrowRight className="motion-arrow h-4 w-4" />
        </a>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {relatedServices.map((related) => (
          <a
            href={`/services/${related.slug}`}
            class="group motion-card flex flex-col justify-between gap-8 rounded-[24px] border border-[var(--hairline)] bg-[var(--cream)] p-6 md:p-7"
          >
            <div>
              <p class="font-display text-xl font-semibold leading-tight tracking-normal text-charcoal">
                {related.shortName ?? related.name}
              </p>
              <p class="mt-2.5 leading-relaxed text-muted-foreground">{related.tagline}</p>
            </div>
            <span class="inline-flex items-center gap-2 text-sm font-medium text-charcoal">
              Learn more
              <ArrowRight className="motion-arrow h-4 w-4" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page pb-16 pt-2 md:pb-24">
    <div class="vip-shader-card relative overflow-hidden rounded-[32px] p-8 text-white md:p-14">
      <div class="relative mx-auto flex max-w-3xl flex-col items-center text-center">
        <p class="eyebrow text-white/70">Next step</p>
        <h2 class="display-2 mt-4 text-balance text-white">
          See how {shortName} would fit your shop.
        </h2>
        <p class="mt-5 max-w-[52ch] text-lg leading-relaxed text-white/78">
          Book a consultation — we'll look at your market, your current marketing, and whether
          this is the right move for your shop.
        </p>
        <div class="mt-8 flex flex-col items-center gap-5 sm:flex-row">
          <a
            href={CONSULTATION_URL}
            class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-7 py-4 font-medium text-[var(--navy)] transition hover:-translate-y-0.5 hover:shadow-[0_18px_40px_-18px_rgba(0,0,0,0.5)]"
            data-track-event="consultation_cta_click"
            data-track-slug={service.slug}
            data-track-placement="service_bottom"
          >
            Schedule a Consultation
            <ArrowRight className="h-4 w-4" />
          </a>
          <a
            href="/results"
            class="group inline-flex items-center gap-2 font-medium text-white/85 transition hover:text-white"
          >
            See client results
            <ArrowRight className="motion-arrow h-4 w-4" />
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .faq-item > summary {
    list-style: none;
  }

  .faq-item > summary::-webkit-details-marker {
    display: none;
  }

  .faq-minus {
    display: none;
  }

  .faq-item[open] .faq-plus {
    display: none;
  }

  .faq-item[open] .faq-minus {
    display: inline;
  }
</style>
