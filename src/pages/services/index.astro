---
import { ArrowRight, ArrowUpRight, Check, Star } from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHero from "@/components/site/PageHero.astro";
import { CONSULTATION_URL, services } from "@/lib/services";
import { getServiceDetail } from "@/lib/service-details";
import { siteMedia } from "@/lib/site-media";

const vip = services.find((service) => service.featured) ?? services[0];
const rest = services.filter((service) => !service.featured);
const vipDetail = getServiceDetail(vip.slug);
---

<BaseLayout
  title="Services — Turnkey Marketing"
  description="A coordinated marketing ecosystem for auto repair shops — VIP Marketing Manager, direct mail, digital, retention, and more."
  path="/services"
  ogTitle="Services — Turnkey Marketing"
  ogImage={siteMedia.about.team.src}
>
  <PageHero
    eyebrow="Services"
    title="Marketing support built around the whole shop."
    description="You do not need more disconnected vendors. You need one team that sees the whole board, knows the repair-shop world, and moves the plan forward every week."
    image={siteMedia.team.visionExpoConversation}
    ctaHref={CONSULTATION_URL}
    ctaLabel="Schedule a Consultation"
    secondaryHref="#service-list"
    secondaryLabel="See the services"
  >
    <div slot="badge" class="card-float floaty absolute -left-3 bottom-8 px-5 py-4 md:left-4">
      <div class="flex items-center gap-2">
        <Star className="h-4 w-4 text-[var(--green)]" fill="currentColor" />
        <p class="text-xs font-medium text-charcoal/60">300+ shops</p>
      </div>
      <p class="mt-1 font-display text-lg font-semibold tracking-normal text-charcoal">
        One coordinated plan
      </p>
    </div>
  </PageHero>

  <section class="bg-[var(--off-white)] py-16 md:py-24">
    <div class="container-page">
      <a
        href={`/services/${vip.slug}`}
        class="group grid gap-10 overflow-hidden rounded-[32px] bg-white p-7 shadow-[0_30px_90px_-60px_rgba(20,22,28,0.34)] md:p-10 lg:grid-cols-12 lg:items-center"
        data-track-event="service_cta_click"
        data-track-slug={vip.slug}
        data-track-placement="services_hero"
      >
        <div class="lg:col-span-5">
          <div class="flex items-center gap-2">
            <Star className="h-4 w-4 text-[var(--green)]" fill="currentColor" />
            <p class="text-xs uppercase tracking-[0.18em] text-charcoal/60">
              Flagship service
            </p>
          </div>
          <h2 class="display-2 mt-5 max-w-[10ch] text-balance text-charcoal">
            {vip.name}
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-charcoal/65">
            {vip.tagline}
          </p>
          <span class="mt-8 inline-flex items-center gap-2 font-medium text-charcoal">
            Explore VIP Marketing Manager
            <ArrowUpRight className="h-4 w-4 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </span>
        </div>

        <div class="lg:col-span-4">
          <ul class="grid gap-x-6 gap-y-3 sm:grid-cols-2 lg:grid-cols-1">
            {vipDetail.included.map((item) => (
              <li class="flex items-center gap-3 text-[0.95rem] font-medium text-charcoal">
                <span class="inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-[var(--key-blue-soft)]">
                  <Check className="h-3.5 w-3.5 text-[var(--navy)]" />
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="relative lg:col-span-3">
          <div class="aspect-[4/3] overflow-hidden rounded-[24px] bg-[var(--off-white)]">
            <img
              src={vipDetail.image.src}
              alt={vipDetail.image.alt}
              width="900"
              height="675"
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
              style={`object-position: ${vipDetail.image.position};`}
            />
          </div>
        </div>
      </a>
    </div>
  </section>

  <section id="service-list" class="container-page py-16 md:py-24">
    <div class="flex items-center gap-5">
      <p class="text-sm font-semibold text-charcoal/70">Services</p>
      <div class="h-px flex-1 bg-charcoal/10"></div>
    </div>

    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {rest.map((service, index) => {
        const detail = getServiceDetail(service.slug);
        return (
          <a
            href={`/services/${service.slug}`}
            class="group grid min-h-[280px] gap-7 rounded-[28px] bg-white p-7 transition hover:-translate-y-1 hover:shadow-[0_28px_70px_-48px_rgba(20,22,28,0.35)] md:grid-cols-[1fr_180px]"
            data-track-event="service_cta_click"
            data-track-slug={service.slug}
          >
            <div>
              <span class="text-xs text-muted-foreground tabular-nums">
                {String(index + 2).padStart(2, "0")}
              </span>
              <h2 class="mt-4 font-display text-3xl font-semibold leading-tight tracking-normal text-charcoal">
                {service.name}
              </h2>
              <p class="mt-4 max-w-md text-muted-foreground">
                {service.tagline}
              </p>
              <span class="mt-8 inline-flex items-center gap-2 font-medium text-charcoal">
                View service
                <ArrowRight className="h-4 w-4 transition group-hover:translate-x-1" />
              </span>
            </div>
            <div class="aspect-[4/3] overflow-hidden rounded-[24px] bg-[var(--off-white)] md:aspect-auto">
              <img
                src={detail.image.src}
                alt={detail.image.alt}
                width="540"
                height="560"
                loading="lazy"
                decoding="async"
                class:list={[
                  "h-full w-full transition duration-500 group-hover:scale-[1.04]",
                  detail.imageFit === "contain" ? "object-contain p-6" : "object-cover",
                ]}
                style={`object-position: ${detail.image.position};`}
              />
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <section class="container-page pb-24 md:pb-32">
    <a
      href={CONSULTATION_URL}
      class="flex flex-col gap-8 rounded-[32px] bg-[var(--charcoal)] p-8 text-white transition hover:bg-[var(--navy)] md:flex-row md:items-center md:justify-between md:p-12"
      data-track-event="consultation_cta_click"
      data-track-placement="services_index"
    >
      <span class="font-display text-3xl font-semibold leading-tight tracking-normal md:text-4xl">
        Want us to help sort what your shop actually needs?
      </span>
      <span class="inline-flex items-center gap-2 font-medium">
        Schedule a Consultation
        <ArrowRight className="h-4 w-4" />
      </span>
    </a>
  </section>
</BaseLayout>
