---
import { ArrowRight, Star } from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CONSULTATION_URL } from "@/lib/services";
import { prospectResultStories, videoTestimonials } from "@/lib/proof";

const legendaryResult = prospectResultStories[0]!;
const killianResult = prospectResultStories[1]!;
const dannysResult = prospectResultStories[2]!;
const ggResult = prospectResultStories[4]!;
const nashvilleResult = prospectResultStories[5]!;
const proResult = prospectResultStories[6]!;
---

<BaseLayout
  title="Auto Repair Marketing Results — Turnkey Marketing"
  description="See how independent auto repair shops grew revenue, car count, returning customers, capacity, and locations while working with Turnkey Marketing."
  path="/results"
  ogTitle="Auto Repair Marketing Results — Turnkey Marketing"
>
  <section class="relative overflow-hidden bg-white">
    <div class="container-page flex min-h-[62vh] items-center justify-center pt-16 pb-10 text-center md:min-h-[68vh] md:pt-24 md:pb-12">
      <div class="mx-auto max-w-6xl">
        <p class="eyebrow text-[var(--key-blue)]">Client results</p>
        <h1 class="display-1 mt-6">
          <span class="block text-[var(--navy)]">More cars.</span>
          <span class="block text-[var(--key-blue)]">More calls.</span>
          <span class="block text-[var(--green)]">More revenue.</span>
        </h1>
        <div class="mt-9 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center">
          <a href={CONSULTATION_URL} class="btn-primary">
            Let’s grow my shop! <ArrowRight className="motion-arrow h-4 w-4" />
          </a>
          <a href="#shop-stories" class="btn-ghost border-[var(--navy)]/20 text-[var(--navy)]">
            Show me the proof <span class="text-lg leading-none" aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="shop-stories" class="scroll-mt-24 bg-white py-16 md:py-24">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <p class="eyebrow text-[var(--key-blue)]">Shop stories</p>
        <h2 class="mt-5 text-balance font-display text-4xl font-semibold leading-tight text-charcoal md:text-6xl">Real shops. Real growth.</h2>
      </div>

      <article class="mt-12 rounded-[28px] bg-[var(--navy)] p-7 text-white md:p-10 lg:p-12">
        <img src={killianResult.logoSrc} alt={`${killianResult.name} logo`} loading="lazy" decoding="async" class="h-16 w-auto max-w-[150px] rounded-xl bg-white p-2 object-contain" />
        <h3 class="mt-7 max-w-3xl text-balance font-display text-4xl font-semibold leading-[1.02] md:text-6xl">From one location to four.</h3>
        <p class="mt-6 max-w-4xl text-lg leading-relaxed text-white/65 md:text-xl">
          Killian Auto Pros expanded from one shop to four while combined average revenue grew from <strong class="font-semibold text-white">$662K to $971K</strong> and average car count grew from <strong class="font-semibold text-white">1,236 to 1,706</strong> across the three locations with comparable data.
        </p>
      </article>

      <div class="mt-6">
        <article class="flex min-h-[390px] flex-col justify-between rounded-[28px] bg-[var(--off-white)] p-7 md:p-10">
          <div>
            <img src={dannysResult.logoSrc} alt="Tech One Automotive logo" loading="lazy" decoding="async" class="h-16 w-24 rounded-xl bg-white p-2 object-contain" />
            <h3 class="mt-7 max-w-lg text-balance font-display text-4xl font-semibold leading-[1.02] text-charcoal md:text-5xl">$1 million in growth and a second location.</h3>
          </div>
          <div class="mt-10">
            <div class="font-display text-5xl font-semibold leading-none text-[var(--key-blue)] md:text-6xl">$1.8M → $2.8M</div>
            <p class="mt-3 text-sm text-charcoal/50">Annual revenue · 2022 to 2023 · approximately +56%</p>
            <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 border-t border-charcoal/15 pt-5 text-sm font-medium text-charcoal/60">
              <span>Nearly 1,000 more cars</span>
              <span>Full bays during the second shop’s soft launch</span>
            </div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <section class="bg-[var(--off-white)] py-16 md:py-24">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2 text-xs text-charcoal/60">
          <div class="flex text-[var(--green)]">
            {[0, 1, 2, 3, 4].map(() => (
              <Star className="h-3.5 w-3.5" fill="currentColor" />
            ))}
          </div>
          <span>Video testimonials</span>
        </div>
        <h2 class="display-2 mt-5 text-balance text-charcoal">
          Hear it from shop owners.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-charcoal/65">
          These testimonial videos are optimized for the page so visitors can
          hear directly from shop owners without leaving the site.
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-5 lg:grid-cols-3">
        {videoTestimonials.map((video) => (
          <article class="motion-card overflow-hidden rounded-[30px] bg-white">
            <div class="flex justify-center bg-white px-3 pt-3">
              <video
                class="aspect-[9/16] max-h-[520px] w-full max-w-[292px] rounded-[24px] bg-black object-cover"
                controls
                preload="metadata"
                poster={video.posterSrc}
                title={`${video.name} testimonial video`}
                aria-label={video.posterAlt}
                playsinline
              >
                <source src={video.videoSrc} type="video/mp4" />
                <a href={video.videoSrc}>Download {video.name} testimonial video</a>
              </video>
            </div>
            <div class="p-6">
              <h3 class="font-display text-2xl font-semibold text-charcoal">
                {video.name}
              </h3>
              <p class="mt-1 text-sm text-charcoal/60">{video.shop}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--navy)] py-20 md:py-28">
    <div class="container-page">
      <div class="mx-auto max-w-4xl text-center">
        <p class="eyebrow text-[var(--green)]">What growth can unlock</p>
        <h2 class="mt-5 text-balance font-display text-4xl font-semibold leading-tight text-white md:text-6xl">More room to hire, expand, and lead.</h2>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        <article class="flex min-h-[370px] flex-col justify-between rounded-[28px] bg-[rgba(255,255,255,0.08)] p-7 text-white shadow-[0_24px_70px_rgba(8,18,66,0.24)] md:p-9">
          <div>
            <div class="flex h-20 w-48 items-center justify-center rounded-xl bg-white p-2.5">
              <img src={ggResult.logoSrc} alt={`${ggResult.name} logo`} loading="lazy" decoding="async" class="h-full w-full object-contain" />
            </div>
            <p class="mt-6 text-[10px] font-semibold uppercase tracking-[0.2em] text-[var(--green)]">March revenue growth</p>
          </div>
          <div class="mt-12">
            <div class="font-display text-6xl font-semibold leading-none text-white">38%</div>
            <p class="mt-5 max-w-xs text-sm leading-relaxed text-white/50">From $392K to $540K in March revenue</p>
          </div>
        </article>
        <article class="flex min-h-[370px] flex-col justify-between rounded-[28px] bg-[rgba(255,255,255,0.08)] p-7 text-white shadow-[0_24px_70px_rgba(8,18,66,0.24)] md:p-9">
          <div>
            <div class="flex h-20 w-48 items-center justify-center rounded-xl bg-white p-2.5">
              <img src={nashvilleResult.logoSrc} alt={`${nashvilleResult.name} logo`} loading="lazy" decoding="async" class="h-full w-full object-contain" />
            </div>
            <p class="mt-6 text-[10px] font-semibold uppercase tracking-[0.2em] text-[#8bc9f3]">Revenue milestone</p>
          </div>
          <div class="mt-12">
            <div class="font-display text-6xl font-semibold leading-none text-white">$1M+</div>
            <p class="mt-5 max-w-xs text-sm leading-relaxed text-white/50">Reached during the Nashville shop’s second year</p>
          </div>
        </article>
        <article class="flex min-h-[370px] flex-col justify-between rounded-[28px] bg-[rgba(255,255,255,0.08)] p-7 text-white shadow-[0_24px_70px_rgba(8,18,66,0.24)] md:p-9">
          <div>
            <div class="flex h-20 w-48 items-center justify-center rounded-xl bg-white p-2.5">
              <img src={proResult.logoSrc} alt={`${proResult.name} logo`} loading="lazy" decoding="async" class="h-full w-full object-contain" />
            </div>
            <p class="mt-6 text-[10px] font-semibold uppercase tracking-[0.2em] text-[var(--green)]">Return on ad spend</p>
          </div>
          <div class="mt-12">
            <div class="font-display text-6xl font-semibold leading-none text-[var(--green)]">3.74×</div>
            <p class="mt-5 max-w-xs text-sm leading-relaxed text-white/50">$3.74 tracked revenue for every $1 in advertising</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-white py-14 md:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-5xl rounded-[32px] bg-[var(--navy)] px-7 py-12 text-center text-white shadow-[0_28px_80px_rgba(24,42,109,0.16)] md:px-12 md:py-16">
        <h2 class="mx-auto max-w-4xl text-balance font-display text-4xl font-semibold leading-[1.05] md:text-6xl">What could happen to your shop if you let the experts handle your marketing?</h2>
        <a href={CONSULTATION_URL} class="mt-9 inline-flex items-center gap-2 rounded-full bg-[var(--green)] px-8 py-4 text-base font-semibold text-charcoal shadow-[0_14px_34px_rgba(142,203,63,0.22)] transition duration-300 hover:-translate-y-0.5 hover:bg-white hover:shadow-[0_18px_42px_rgba(255,255,255,0.16)]">
          Let’s find out <ArrowRight className="motion-arrow h-4 w-4" />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
