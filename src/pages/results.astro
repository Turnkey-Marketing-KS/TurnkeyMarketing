---
import { ArrowRight, MapPin, Star, TrendingUp } from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CONSULTATION_URL } from "@/lib/services";
import { videoTestimonials } from "@/lib/proof";
import {
  bandStats,
  demandQuote,
  featuredResult,
  killianStory,
  moreResults,
} from "@/lib/results-content";
---

<BaseLayout
  title="Auto Repair Marketing Results — Turnkey Marketing"
  description="Before-and-after results from independent auto repair shops working with Turnkey Marketing — revenue, car count, returning customers, and growth into new locations."
  path="/results"
  ogTitle="Auto Repair Marketing Results — Turnkey Marketing"
>
  <section class="relative overflow-hidden bg-white">
    <div class="container-page flex min-h-[62vh] items-center justify-center pt-16 pb-10 text-center md:min-h-[68vh] md:pt-24 md:pb-12">
      <div class="mx-auto max-w-6xl">
        <p class="eyebrow text-[var(--key-blue)]">Client results</p>
        <h1 class="display-1 mt-6">
          <span class="block text-[var(--navy)]">More cars.</span>
          <span class="block text-[var(--key-blue)]">More calls.</span>
          <span class="block text-[var(--green)]">More revenue.</span>
        </h1>
        <div class="mt-9 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center">
          <a href={CONSULTATION_URL} class="btn-primary">
            Let’s grow my shop! <ArrowRight className="motion-arrow h-4 w-4" />
          </a>
          <a href="#featured-result" class="btn-ghost border-[var(--navy)]/20 text-[var(--navy)]">
            Show me the proof <span class="text-lg leading-none" aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="featured-result" class="scroll-mt-24 border-t border-[var(--hairline)] bg-white py-16 md:py-24">
    <div class="container-page">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-16">
        <div class="lg:col-span-5">
          <p class="eyebrow flex items-center gap-3">
            <span class="h-px w-8 bg-[var(--key-blue)] md:w-10" aria-hidden="true"></span>
            Featured result
          </p>
          <h2 class="display-3 mt-5 text-balance text-charcoal">
            {featuredResult.headline}
          </h2>
          <p class="mt-5 leading-relaxed text-charcoal/65 md:text-lg">{featuredResult.body}</p>
          <img
            src={featuredResult.logoSrc}
            alt={`${featuredResult.name} logo`}
            loading="lazy"
            decoding="async"
            class="mt-8 h-16 w-auto object-contain"
          />
          <p class="mt-6 text-sm text-charcoal/45">{featuredResult.footnote}</p>
        </div>

        <div class="lg:col-span-7">
          <figure>
            <div role="img" aria-label={featuredResult.chart.ariaLabel}>
              <div class="flex h-[300px] items-end justify-center gap-8 border-b-2 border-[var(--hairline)] md:h-[340px] md:gap-14">
                {featuredResult.chart.bars.map((bar, index) => (
                  <div class="flex h-full w-28 flex-col items-center justify-end md:w-40">
                    {bar.tag && (
                      <span class="mb-2 rounded-full bg-[var(--key-blue-soft)] px-3 py-1 text-xs font-semibold text-[var(--navy)]">
                        {bar.tag}
                      </span>
                    )}
                    <p class="mb-3 font-display text-lg font-semibold tracking-tight text-charcoal md:text-2xl">
                      {bar.value}
                    </p>
                    <div
                      class="result-bar w-full rounded-t-md"
                      style={`height: ${bar.height}%; background: ${bar.color}; transition-delay: ${index * 160}ms;`}
                    >
                    </div>
                  </div>
                ))}
              </div>
              <div class="flex justify-center gap-8 pt-3 md:gap-14">
                {featuredResult.chart.bars.map((bar) => (
                  <p class="w-28 text-center text-sm font-medium text-charcoal/55 md:w-40">
                    {bar.label}
                  </p>
                ))}
              </div>
            </div>
            <figcaption class="mt-6 text-center text-sm text-charcoal/45">
              {featuredResult.chart.caption}
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--navy)] py-16 text-white md:py-24">
    <div class="container-page">
      <h2 class="display-3 max-w-[20ch] text-balance text-white">And it’s not a one-off.</h2>
      <div class="mt-12 grid gap-10 md:grid-cols-3 md:gap-8 lg:gap-12">
        {bandStats.map((stat) => (
          <div class="border-t border-white/15 pt-7">
            <TrendingUp className="h-5 w-5 text-[var(--green)]" />
            <p class="mt-4 font-display text-5xl font-semibold leading-none tracking-tight text-white md:text-6xl">
              {stat.value}
            </p>
            <p class="mt-4 max-w-[38ch] leading-relaxed text-white/65">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-24">
    <div class="container-page">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-center lg:gap-16">
        <div class="lg:col-span-5">
          <p class="eyebrow flex items-center gap-3">
            <span class="h-px w-8 bg-[var(--key-blue)] md:w-10" aria-hidden="true"></span>
            Growth story
          </p>
          <h2 class="display-3 mt-5 text-balance text-charcoal">{killianStory.headline}</h2>
          <p class="mt-5 leading-relaxed text-charcoal/65 md:text-lg">{killianStory.body}</p>
          <img
            src={killianStory.logoSrc}
            alt={`${killianStory.name} logo`}
            loading="lazy"
            decoding="async"
            class="mt-8 h-14 w-auto object-contain"
          />
          <p class="mt-6 text-sm text-charcoal/45">{killianStory.footnote}</p>
        </div>

        <div class="lg:col-span-7">
          <div class="grid gap-4 sm:grid-cols-2">
            {killianStory.locations.map((location) => {
              const [milestone, result] = location.detail.split(" · ");

              return (
                <div class="group relative flex min-h-[174px] flex-col overflow-hidden rounded-[26px] border border-[rgba(63,140,203,0.22)] bg-[linear-gradient(145deg,#ffffff_0%,#f4f8fd_100%)] p-6 shadow-[0_22px_55px_-42px_rgba(35,46,102,0.48)] transition-[border-color,box-shadow,transform] duration-300 ease-out hover:-translate-y-1 hover:border-[rgba(63,140,203,0.48)] hover:shadow-[0_30px_70px_-44px_rgba(35,46,102,0.58)] md:min-h-[190px] md:p-7">
                  <span class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-[var(--key-blue)] via-[#79d5f6] to-[var(--green)]" aria-hidden="true"></span>

                  <div class="flex items-start justify-between gap-5">
                    <div>
                      <p class="font-display text-2xl font-semibold tracking-tight text-charcoal">
                        {location.name}
                      </p>
                      <p class="mt-2 text-sm leading-relaxed text-charcoal/55">{milestone}</p>
                    </div>
                    <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[var(--key-blue-soft)] text-[var(--navy)] shadow-[0_12px_28px_-20px_rgba(35,46,102,0.5)] transition-colors duration-300 group-hover:bg-[var(--key-blue)] group-hover:text-white">
                      <MapPin className="h-5 w-5" aria-hidden="true" />
                    </span>
                  </div>

                  {result && (
                    <p class="mt-auto pt-5 text-sm font-semibold leading-relaxed text-[var(--key-blue)]">
                      {result}
                    </p>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-[var(--hairline)] bg-white py-16 md:py-24">
    <div class="container-page">
      <div>
        <div>
          <p class="eyebrow flex items-center gap-3">
            <span class="h-px w-8 bg-[var(--key-blue)] md:w-10" aria-hidden="true"></span>
            More wins
          </p>
          <h2 class="display-3 mt-5 text-balance text-charcoal">More before &amp; afters.</h2>
        </div>
      </div>

      <div class="mt-12 grid gap-x-10 gap-y-12 md:grid-cols-2 lg:grid-cols-3">
        {moreResults.map((result) => (
          <div>
            <img
              src={result.logoSrc}
              alt={`${result.name} logo`}
              loading="lazy"
              decoding="async"
              class="h-10 w-auto max-w-[150px] object-contain"
            />
            <p class="mt-5 font-display text-4xl font-semibold leading-none tracking-tight text-[var(--navy)]">
              {result.delta}
            </p>
            <p class="mt-3 max-w-[34ch] font-medium leading-snug text-charcoal">{result.line}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--charcoal)] py-16 text-white md:py-24">
    <div class="container-page">
      <figure class="mx-auto max-w-4xl text-center">
        <img
          src={demandQuote.logoSrc}
          alt={`${demandQuote.attribution} logo`}
          loading="lazy"
          decoding="async"
          class="mx-auto h-10 w-auto object-contain"
        />
        <blockquote class="mt-8 font-display text-2xl font-semibold leading-snug tracking-tight text-white md:text-4xl md:leading-[1.2]">
          “{demandQuote.quote}”
        </blockquote>
        <figcaption class="mt-7 font-medium text-white/85">{demandQuote.attribution}</figcaption>
      </figure>
    </div>
  </section>

  <section class="bg-[var(--off-white)] py-16 md:py-24">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2 text-xs text-charcoal/60">
          <div class="flex text-[var(--green)]">
            {[0, 1, 2, 3, 4].map(() => (
              <Star className="h-3.5 w-3.5" fill="currentColor" />
            ))}
          </div>
          <span>Video testimonials</span>
        </div>
        <h2 class="display-2 mt-5 text-balance text-charcoal">
          Hear it from shop owners.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-charcoal/65">
          These testimonial videos are optimized for the page so visitors can
          hear directly from shop owners without leaving the site.
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-5 lg:grid-cols-3">
        {videoTestimonials.map((video) => (
          <article class="motion-card overflow-hidden rounded-[30px] bg-white">
            <div class="flex justify-center bg-white px-3 pt-3">
              <video
                class="aspect-[9/16] max-h-[520px] w-full max-w-[292px] rounded-[24px] bg-black object-cover"
                controls
                preload="metadata"
                poster={video.posterSrc}
                title={`${video.name} testimonial video`}
                aria-label={video.posterAlt}
                playsinline
              >
                <source src={video.videoSrc} type="video/mp4" />
                <a href={video.videoSrc}>Download {video.name} testimonial video</a>
              </video>
            </div>
            <div class="p-6">
              <h3 class="font-display text-2xl font-semibold text-charcoal">
                {video.name}
              </h3>
              <p class="mt-1 text-sm text-charcoal/60">{video.shop}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-14 md:py-20">
    <div class="container-page">
      <div class="mx-auto max-w-5xl rounded-[32px] bg-[var(--navy)] px-7 py-12 text-center text-white shadow-[0_28px_80px_rgba(24,42,109,0.16)] md:px-12 md:py-16">
        <h2 class="mx-auto max-w-4xl text-balance font-display text-4xl font-semibold leading-[1.05] md:text-6xl">What could happen to your shop if you let the experts handle your marketing?</h2>
        <a href={CONSULTATION_URL} class="mt-9 inline-flex items-center gap-2 rounded-full bg-[var(--green)] px-8 py-4 text-base font-semibold text-charcoal shadow-[0_14px_34px_rgba(142,203,63,0.22)] transition duration-300 hover:-translate-y-0.5 hover:bg-white hover:shadow-[0_18px_42px_rgba(255,255,255,0.16)]">
          Let’s find out <ArrowRight className="motion-arrow h-4 w-4" />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .result-bar {
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 900ms var(--ease-emphasized);
  }

  section.is-visible .result-bar {
    transform: scaleY(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .result-bar {
      transform: scaleY(1);
      transition: none;
    }
  }
</style>
