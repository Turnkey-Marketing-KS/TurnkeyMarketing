---
import { ArrowRight, BarChart3, PlayCircle, Quote, Star, TrendingUp } from "lucide-react";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CONSULTATION_URL } from "@/lib/services";
import {
  ownerTestimonials,
  resultMetricProof,
  reviewGrowthProof,
  videoTestimonials,
} from "@/lib/proof";

const accentVars = {
  green: "--proof-accent: var(--green); --proof-soft: rgba(146, 204, 64, 0.16);",
  blue: "--proof-accent: var(--key-blue); --proof-soft: rgba(68, 145, 209, 0.16);",
  navy: "--proof-accent: var(--navy); --proof-soft: rgba(35, 46, 102, 0.12);",
} as const;

const proofHighlights = [
  { value: "500+", label: "cars after onboarding", client: "Auto Medics" },
  { value: "130%", label: "YoY revenue growth", client: "Torque European" },
  { value: "15-20", label: "reviews per month", client: "Chris Matthews Automotive" },
];
---

<BaseLayout
  title="Auto Repair Marketing Results — Turnkey Marketing"
  description="Client-specific examples from auto repair shops using Turnkey Marketing, including revenue growth, review growth, and shop-owner video testimonials."
  path="/results"
  ogTitle="Auto Repair Marketing Results — Turnkey Marketing"
>
  <section class="bg-white py-16 md:py-24">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.85fr] lg:items-end">
        <div>
          <p class="eyebrow text-[var(--key-blue)]">Results</p>
          <h1 class="display-1 mt-5 max-w-4xl text-balance text-charcoal">
            Proof from auto repair shops.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-relaxed text-charcoal/65 md:text-xl">
            Client-specific examples from shops that trusted Turnkey to connect
            the plan, campaigns, reporting, and follow-through. These are real
            examples, not universal guarantees.
          </p>
        </div>

        <div class="rounded-[30px] bg-[var(--off-white)] p-6 md:p-8">
          <div class="flex items-center justify-between gap-4 border-b hairline pb-5">
            <div>
              <p class="text-xs font-semibold uppercase text-[var(--key-blue)]">
                Snapshot
              </p>
              <h2 class="mt-2 font-display text-2xl font-semibold text-charcoal">
                Client-specific wins
              </h2>
            </div>
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white text-[var(--green)]">
              <TrendingUp className="h-6 w-6" />
            </div>
          </div>

          <div class="mt-5 grid gap-3">
            {proofHighlights.map((item) => (
              <div class="grid grid-cols-[auto_1fr] gap-4 rounded-2xl bg-white p-4">
                <div class="font-display text-3xl font-semibold text-charcoal">
                  {item.value}
                </div>
                <div class="min-w-0">
                  <div class="font-medium text-charcoal">{item.label}</div>
                  <div class="mt-1 text-sm text-charcoal/55">{item.client}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--off-white)] py-16 md:py-24">
    <div class="container-page">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div>
          <p class="eyebrow text-[var(--key-blue)]">Measured wins</p>
          <h2 class="display-2 mt-4 max-w-3xl text-balance text-charcoal">
            Results shown as clear numbers.
          </h2>
        </div>
        <p class="max-w-2xl text-lg leading-relaxed text-charcoal/65 lg:justify-self-end">
          Instead of leaning on screenshots, these cards translate the strongest
          proof points into simple visuals a shop owner can understand quickly.
        </p>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {resultMetricProof.map((item) => (
          <article
            class="motion-card overflow-hidden rounded-[30px] bg-white p-7 md:p-8"
            style={accentVars[item.accent]}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-[var(--key-blue)]">
                  {item.eyebrow}
                </p>
                <h3 class="mt-4 font-display text-2xl font-semibold text-charcoal">
                  {item.client}
                </h3>
              </div>
              <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[var(--proof-soft)] text-[var(--proof-accent)]">
                <BarChart3 className="h-5 w-5" />
              </div>
            </div>

            <div class="mt-8">
              <div class="font-display text-6xl font-semibold leading-none text-charcoal">
                {item.metric}
              </div>
              <p class="mt-3 text-lg font-medium leading-snug text-charcoal">
                {item.label}
              </p>
              <p class="mt-4 text-sm leading-relaxed text-charcoal/60">
                {item.context}
              </p>
            </div>

            <div class="mt-8 rounded-3xl bg-[var(--off-white)] p-5">
              <div class="mb-4 flex items-center justify-between text-xs font-medium text-charcoal/55">
                <span>{item.chartLabel}</span>
                <span>Client example</span>
              </div>
              <div class="flex h-32 items-end gap-2">
                {item.chartValues.map((value) => (
                  <div class="flex flex-1 items-end">
                    <div
                      class="w-full rounded-t-lg bg-[var(--proof-accent)]"
                      style={`height: ${value}%; opacity: ${0.32 + value / 150};`}
                    ></div>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 md:py-24">
    <div class="container-page">
      <div class="overflow-hidden rounded-[36px] bg-[var(--off-white)] p-6 md:p-8 lg:p-10">
        <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-stretch">
          <div class="rounded-[30px] bg-white p-7 md:p-8">
            <p class="eyebrow text-[var(--key-blue)]">Google reviews</p>
            <h2 class="mt-5 max-w-xl font-display text-4xl font-semibold leading-[0.98] tracking-normal text-charcoal md:text-5xl">
              More reviews. More trust before the call.
            </h2>
            <p class="mt-5 max-w-xl text-lg leading-relaxed text-charcoal/65">
              Reputation work helps local drivers choose the shop before they
              ever pick up the phone.
            </p>

            <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
              <div class="rounded-3xl border hairline bg-[var(--off-white)] p-5">
                <div class="text-sm font-medium text-charcoal/55">Before</div>
                <div class="mt-3 font-display text-4xl font-semibold text-charcoal">
                  1-2
                </div>
                <div class="mt-1 text-sm text-charcoal/60">reviews per month</div>
              </div>
              <div class="rounded-3xl bg-[var(--green)] p-5 text-charcoal">
                <div class="text-sm font-medium text-charcoal/65">After</div>
                <div class="mt-3 font-display text-4xl font-semibold">
                  15-20
                </div>
                <div class="mt-1 text-sm text-charcoal/70">reviews per month</div>
              </div>
            </div>
          </div>

          <article
            class="motion-card relative overflow-hidden rounded-[30px] bg-[var(--navy)] p-7 text-white md:p-8"
            style={accentVars[reviewGrowthProof.accent]}
          >
            <div class="absolute right-0 top-0 h-40 w-40 rounded-bl-full bg-[var(--green)]/20"></div>
            <div class="relative">
              <div class="flex flex-wrap items-start justify-between gap-5">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-widest text-[var(--green)]">
                    {reviewGrowthProof.client}
                  </p>
                  <h3 class="mt-4 max-w-xl font-display text-3xl font-semibold leading-tight md:text-4xl">
                    A consistent review engine, not occasional luck.
                  </h3>
                </div>
                <div class="rounded-full bg-white/10 px-4 py-2 text-sm font-medium text-white/75">
                  Client example
                </div>
              </div>

              <div class="mt-8 rounded-[26px] bg-white p-5 text-charcoal md:p-6">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="text-sm font-medium text-charcoal/55">
                      {reviewGrowthProof.chartLabel}
                    </p>
                    <p class="mt-1 text-sm text-charcoal/55">
                      Activity became steady enough to support visibility and trust.
                    </p>
                  </div>
                  <div class="hidden rounded-full bg-[var(--key-blue-soft)] px-3 py-1 text-sm font-semibold text-[var(--key-blue)] sm:block">
                    Upward trend
                  </div>
                </div>

                <div class="mt-8 grid h-40 grid-cols-8 items-end gap-2 border-b hairline pb-3">
                  {reviewGrowthProof.chartValues.map((value, index) => (
                    <div class="flex h-full items-end">
                      <div
                        class:list={[
                          "w-full rounded-t-xl",
                          index < 3 ? "bg-[var(--key-blue-soft)]" : "bg-[var(--green)]",
                        ]}
                        style={`height: ${value}%;`}
                      ></div>
                    </div>
                  ))}
                </div>

                <div class="mt-3 flex items-center justify-between text-xs font-medium text-charcoal/45">
                  <span>Occasional</span>
                  <span>Consistent</span>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--off-white)] py-16 md:py-24">
    <div class="container-page">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2 text-xs text-charcoal/60">
          <div class="flex text-[var(--green)]">
            {[0, 1, 2, 3, 4].map(() => (
              <Star className="h-3.5 w-3.5" fill="currentColor" />
            ))}
          </div>
          <span>Video testimonials</span>
        </div>
        <h2 class="display-2 mt-5 text-balance text-charcoal">
          Hear it from shop owners.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-charcoal/65">
          These testimonial videos are optimized for the page so visitors can
          hear directly from shop owners without leaving the site.
        </p>
      </div>

      <div class="mt-12 grid gap-5 lg:grid-cols-3">
        {videoTestimonials.map((video) => (
          <article class="motion-card overflow-hidden rounded-[30px] bg-white">
            <div class="flex justify-center bg-white px-3 pt-3">
              <video
                class="aspect-[9/16] max-h-[520px] w-full max-w-[292px] rounded-[24px] bg-black object-cover"
                controls
                preload="metadata"
                poster={video.posterSrc}
                title={`${video.name} testimonial video`}
                aria-label={video.posterAlt}
                playsinline
              >
                <source src={video.videoSrc} type="video/mp4" />
                <a href={video.videoSrc}>Download {video.name} testimonial video</a>
              </video>
            </div>
            <div class="p-6">
              <h3 class="font-display text-2xl font-semibold text-charcoal">
                {video.name}
              </h3>
              <p class="mt-1 text-sm text-charcoal/60">{video.shop}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-16 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow text-[var(--key-blue)]">Written proof</p>
      <h2 class="display-2 mt-5 text-balance text-charcoal">
        Three quotes worth keeping close.
      </h2>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {ownerTestimonials.map((testimonial) => (
        <figure class="motion-card relative flex min-h-[360px] flex-col overflow-hidden rounded-[28px] bg-[var(--off-white)] p-8">
          <Quote className="absolute right-7 top-7 h-10 w-10 text-[var(--key-blue)] opacity-30" aria-hidden="true" />
          <p class="text-xs uppercase tracking-widest text-[var(--key-blue)]">
            {testimonial.marker}
          </p>
          <blockquote class="mt-8 flex-1 font-display text-2xl font-semibold leading-tight text-charcoal">
            “{testimonial.quote}”
          </blockquote>
          <figcaption class="mt-8 border-t hairline pt-6">
            <div class="flex items-center gap-4">
              <img
                src={testimonial.image.src}
                alt={testimonial.image.alt}
                width="96"
                height="96"
                loading="lazy"
                decoding="async"
                class="h-14 w-14 shrink-0 rounded-full object-cover"
                style={`object-position: ${testimonial.image.position};`}
              />
              <div>
                <div class="font-display text-lg font-semibold text-charcoal">
                  {testimonial.name}
                </div>
                <div class="mt-1 text-sm leading-relaxed text-charcoal/60">
                  {testimonial.shop}
                  <br />
                  {testimonial.location}
                </div>
              </div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="container-page pb-24 text-center">
    <a href={CONSULTATION_URL} class="btn-primary">
      Talk about your shop <ArrowRight className="motion-arrow h-4 w-4" />
    </a>
  </section>
</BaseLayout>
