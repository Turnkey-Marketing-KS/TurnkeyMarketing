---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CONSULTATION_URL } from "@/lib/services";
import { siteMedia } from "@/lib/site-media";

const cases = [
  {
    tag: "Second location ramp",
    h: "Built demand after the overhead was already real.",
    m: "A coordinated launch across direct mail, GBP, and digital helped a new location grow into its bigger commitment.",
    image: siteMedia.clients.keeganShopTeam,
  },
  {
    tag: "Retention leak fixed",
    h: "Reactivated 900+ dormant customers.",
    m: "CRM cleanup, service reminders, and a real follow-up cadence recovered revenue already earned.",
    image: siteMedia.shops.mikes,
  },
  {
    tag: "Direct mail turnaround",
    h: "Doubled response on the same list.",
    m: "Sharper market, message, offer, timing, and tracking turned a tired mail program around.",
    image: siteMedia.graphics.directMail,
  },
  {
    tag: "Vendor spend cleaned up",
    h: "Clarified what to keep, cut, and make work harder.",
    m: "One team owning the scoreboard instead of five vendors defending disconnected line items.",
    image: siteMedia.shops.mmTechnician,
  },
  {
    tag: "Quality customer strategy",
    h: "Right cars, better timing, stronger fit.",
    m: "Positioning and messaging tuned around customer quality, capacity, and the work the shop actually wants.",
    image: siteMedia.shops.technicianUnderVehicle,
  },
];
---

<BaseLayout
  title="Results — Turnkey Marketing"
  description="Real outcomes from real auto repair shops — retention wins, direct mail turnarounds, and coordinated vendor spend."
  path="/results"
  ogTitle="Results — Turnkey Marketing"
  ogImage={siteMedia.shops.mmTechnician.src}
>
  <section class="border-b hairline">
    <div class="container-page pt-20 md:pt-28 pb-16">
      <p class="eyebrow">Results</p>
      <h1 class="display-1 mt-6 max-w-[16ch] text-balance">
        Proof lives in the bays.
      </h1>
      <p class="mt-8 text-lg text-muted-foreground max-w-2xl">
        Case studies and stories from shops we've worked alongside. Full
        write-ups coming soon — reach out for details on any of these.
      </p>
    </div>
  </section>

  <section class="container-page py-16">
    <div class="grid gap-6 md:grid-cols-2">
      {cases.map((item) => (
        <div class="group overflow-hidden rounded-2xl border hairline bg-white transition hover:border-[var(--navy)]">
          <div class="aspect-[16/10] overflow-hidden bg-[var(--off-white)]">
            <img
              src={item.image.src}
              alt={item.image.alt}
              width="1400"
              height="933"
              loading="lazy"
              decoding="async"
              class:list={[
                "h-full w-full transition duration-500 group-hover:scale-[1.03]",
                "imageFit" in item && item.imageFit === "contain" ? "object-contain p-8" : "object-cover",
              ]}
              style={`object-position: ${item.image.position};`}
            />
          </div>
          <div class="p-8">
            <p class="text-xs uppercase tracking-widest" style="color: var(--key-blue);">
              {item.tag}
            </p>
            <p class="font-display text-2xl mt-4 text-balance text-charcoal">{item.h}</p>
            <p class="mt-3 text-muted-foreground">{item.m}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="container-page pb-24 text-center">
    <a href={CONSULTATION_URL} target="_blank" rel="noopener" class="btn-primary">
      Talk about your shop →
    </a>
  </section>
</BaseLayout>
