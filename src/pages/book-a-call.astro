---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { GHL_DISCOVERY_CALL_BOOKING_URL } from "@/lib/services";
import { siteMedia } from "@/lib/site-media";
---

<BaseLayout
  title="Book a Strategy Call — Turnkey Marketing"
  description="Pick a time with Chris to talk through your auto repair shop, your current marketing, and what may make sense next."
  path="/book-a-call"
  ogTitle="Book Your Strategy Call with Turnkey"
  ogImage={siteMedia.team.visionExpoConversation.src}
>
  <section class="container-page py-14 md:py-24">
    <div class="mx-auto max-w-4xl text-center">
      <p class="eyebrow" style="color: var(--key-blue);">Discovery call</p>
      <h1 class="page-title mt-5 text-balance text-charcoal">
        Book your strategy call.
      </h1>
      <p class="mx-auto mt-6 max-w-[32ch] text-lg leading-relaxed text-muted-foreground md:max-w-3xl md:text-xl">
        Pick a time with Chris. We’ll use what you share to talk through your
        shop, your current marketing, and what may make sense next.
      </p>
    </div>

    <iframe
      src={GHL_DISCOVERY_CALL_BOOKING_URL}
      class="booking-frame mx-auto mt-10 max-w-5xl md:mt-14"
      id="yu2OePYtPJE21ORfX8a0_1783535857619"
      title="Book a Turnkey Marketing strategy call"
      scrolling="no"
      loading="lazy"
    >
    </iframe>
  </section>

  <script is:inline src="https://link.msgsndr.com/js/form_embed.js"></script>

  <style>
    .booking-frame {
      display: block;
      width: 100%;
      min-height: 980px;
      border: 0;
      background: transparent;
    }

    @media (max-width: 767px) {
      .booking-frame {
        min-height: 1100px;
      }
    }
  </style>
</BaseLayout>
