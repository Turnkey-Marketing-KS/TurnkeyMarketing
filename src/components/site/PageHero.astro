---
import { ArrowRight } from "lucide-react";
import type { SiteImage } from "@/lib/site-media";

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  image?: SiteImage;
  imageFit?: "cover" | "contain";
  ctaHref?: string;
  ctaLabel?: string;
  ctaExternal?: boolean;
  secondaryHref?: string;
  secondaryLabel?: string;
  backHref?: string;
  backLabel?: string;
  accent?: "blue" | "green";
}

const {
  eyebrow,
  title,
  description,
  image,
  imageFit = "cover",
  ctaHref,
  ctaLabel,
  ctaExternal = false,
  secondaryHref,
  secondaryLabel,
  backHref,
  backLabel,
  accent = "blue",
} = Astro.props;

const accentColor = accent === "green" ? "var(--green)" : "var(--key-blue)";
const openCtaExternally = ctaExternal && !ctaHref?.startsWith("/");
---

<section class="border-b hairline bg-white">
  <div class="container-page pt-10 pb-12 md:pt-16 md:pb-20">
    {backHref && backLabel && (
      <a href={backHref} class="inline-flex min-h-11 items-center text-sm text-muted-foreground transition hover:text-charcoal">
        ← {backLabel}
      </a>
    )}

    <div
      class:list={[
        image ? "grid min-w-0 gap-10 lg:grid-cols-12 lg:items-center" : "max-w-4xl",
        backHref ? "mt-7" : "",
      ]}
    >
      <div class={image ? "min-w-0 lg:col-span-6" : "max-w-4xl"}>
        <p class="eyebrow" style={`color: ${accentColor};`}>{eyebrow}</p>
        <h1 class="page-title mt-5 max-w-full text-balance text-charcoal md:mt-6 md:max-w-[16ch]">
          {title}
        </h1>
        {description && (
          <p class="mt-6 max-w-[32ch] text-lg leading-relaxed text-charcoal/65 md:max-w-[48ch] md:text-xl">
            {description}
          </p>
        )}

        {(ctaHref || secondaryHref) && (
          <div class="mt-8 flex flex-col items-stretch gap-4 sm:flex-row sm:items-center md:mt-10 md:gap-6">
            {ctaHref && ctaLabel && (
              <a
                href={ctaHref}
                target={openCtaExternally ? "_blank" : undefined}
                rel={openCtaExternally ? "noopener" : undefined}
                class="btn-primary w-full sm:w-auto"
              >
                {ctaLabel}
                <ArrowRight className="h-4 w-4" />
              </a>
            )}
            {secondaryHref && secondaryLabel && (
              <a
                href={secondaryHref}
                class="inline-flex min-h-11 items-center justify-center gap-2 font-medium text-charcoal/75 transition hover:text-charcoal sm:justify-start"
              >
                {secondaryLabel}
                <ArrowRight className="h-4 w-4" />
              </a>
            )}
          </div>
        )}
      </div>

      {image && (
        <div class="relative min-w-0 lg:col-span-6">
          <div
            class:list={[
              "relative mx-auto aspect-[16/11] w-full max-w-[620px] overflow-hidden rounded-[28px] shadow-[0_34px_90px_-50px_rgba(20,22,28,0.42)] md:rounded-[32px] lg:ml-auto",
              imageFit === "contain" ? "bg-[var(--off-white)]" : "bg-[var(--off-white)]",
            ]}
          >
            <img
              src={image.src}
              alt={image.alt}
              width="1200"
              height="825"
              loading="eager"
              decoding="async"
              class:list={[
                "absolute inset-0 h-full w-full",
                imageFit === "contain" ? "object-contain p-8 md:p-12" : "object-cover",
              ]}
              style={`object-position: ${image.position};`}
            />
          </div>
          <slot name="badge" />
        </div>
      )}
    </div>
  </div>
</section>
