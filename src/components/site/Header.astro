---
import { ArrowUpRight, ChevronDown, Menu, Star, X } from "lucide-react";
import { BOOKING_URL, services } from "@/lib/services";

const LOGO_SRC = "/turnkey-logo.png";
const primaryNav = [
  { label: "Services", href: "/services" },
  { label: "Results", href: "/results" },
  { label: "Resources", href: "/resources" },
  { label: "About", href: "/about" },
];

const vip = services.find((service) => service.featured) ?? services[0];
const rest = services.filter((service) => !service.featured);

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  currentPath === href || currentPath.startsWith(`${href}/`);
---

<header class="fixed top-0 inset-x-0 z-50 pointer-events-none bg-white border-b hairline">
  <div class="container-page">
    <div
      class="pointer-events-auto flex h-[72px] md:h-[88px] items-center justify-between px-0 transition duration-500"
    >
      <a href="/" class="site-logo-link flex items-center" aria-label="Turnkey Marketing home">
        <img
          src={LOGO_SRC}
          alt="Turnkey Marketing"
          width="1110"
          height="271"
          class="h-12 md:h-16 w-auto"
          loading="eager"
          decoding="async"
        />
      </a>

      <nav class="hidden lg:flex items-center gap-1">
        <div class="relative group">
          <a
            href="/services"
            class:list={[
              "site-nav-link flex items-center gap-1 px-4 py-2 text-[0.92rem] transition rounded-full",
              isActive("/services")
                ? "bg-[var(--off-white)] text-charcoal"
                : "text-charcoal/80 hover:text-charcoal",
            ]}
            aria-current={isActive("/services") ? "page" : undefined}
          >
            Services
            <ChevronDown className="h-3.5 w-3.5 transition-transform duration-300 group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true" />
          </a>
          <div
            class="nav-dropdown-panel absolute left-1/2 top-full w-[880px] -translate-x-1/2 translate-y-3 pt-4 opacity-0 pointer-events-none group-hover:translate-y-0 group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100 group-focus-within:pointer-events-auto"
          >
            <div class="overflow-hidden rounded-[30px] border border-[rgba(35,46,102,0.12)] bg-white p-2 shadow-[0_34px_90px_-28px_rgba(20,22,28,0.34),0_14px_36px_-24px_rgba(35,46,102,0.28)]">
              <div class="grid grid-cols-[0.82fr_1.35fr] gap-2">
              <a
                href={`/services/${vip.slug}`}
                class="site-menu-link group/vip relative flex min-h-full flex-col overflow-hidden rounded-[24px] px-6 py-7 text-white"
                style="background: linear-gradient(155deg, var(--key-blue) 0%, var(--navy) 72%);"
              >
                <span class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full bg-white/10 blur-2xl"></span>
                <div class="relative z-10 flex items-center justify-between gap-3">
                  <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-white/12 text-[var(--green)] ring-1 ring-white/15">
                    <Star className="h-5 w-5" />
                  </span>
                  <span class="rounded-full bg-[var(--green)] px-3 py-1 text-[0.61rem] font-bold uppercase tracking-[0.16em] text-[var(--charcoal)]">
                    Whole department
                  </span>
                </div>

                <div class="relative z-10 mt-8">
                  <h2 class="font-display text-[1.75rem] font-semibold leading-[1.02] text-white">
                    {vip.name}
                  </h2>
                  <p class="mt-4 text-sm leading-relaxed text-white/74">
                    We make the plan, keep every vendor moving, and show you what is actually working.
                  </p>
                </div>

                <div class="relative z-10 mt-auto pt-8">
                  <div class="grid gap-2 text-xs font-medium text-white/82">
                    <span class="flex items-center gap-2">
                      <span class="h-1.5 w-1.5 rounded-full bg-[var(--green)]"></span>
                      One team owns the whole plan
                    </span>
                    <span class="flex items-center gap-2">
                      <span class="h-1.5 w-1.5 rounded-full bg-[var(--green)]"></span>
                      Less vendor chasing for you
                    </span>
                  </div>
                  <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-white">
                    See how VIP works
                    <ArrowUpRight className="h-4 w-4 transition-transform duration-300 group-hover/vip:translate-x-0.5 group-hover/vip:-translate-y-0.5" />
                  </span>
                </div>
              </a>

              <div class="rounded-[24px] bg-[var(--off-white)] px-5 py-5">
                <div class="flex items-end justify-between gap-5 px-1">
                  <div>
                    <p class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-[var(--key-blue)]">
                      Individual services
                    </p>
                    <p class="mt-1.5 text-sm text-charcoal/58">Start with one service, or add support as you need it.</p>
                  </div>
                  <a href="/services" class="shrink-0 text-xs font-semibold text-[var(--navy)] transition hover:text-[var(--key-blue)]">
                    View all
                  </a>
                </div>

                <div class="mt-4 grid grid-cols-2 gap-2">
                  {rest.map((service) => (
                    <a
                      href={`/services/${service.slug}`}
                      class="site-menu-link group/service min-w-0 rounded-2xl border border-[rgba(63,140,203,0.2)] bg-white px-4 py-3.5 shadow-[0_12px_30px_-28px_rgba(35,46,102,0.5)] transition hover:border-[var(--key-blue)] hover:bg-[var(--key-blue)] hover:shadow-[0_18px_36px_-26px_rgba(35,46,102,0.5)]"
                    >
                      <div class="flex items-center justify-between gap-3">
                        <span class="truncate text-[0.9rem] font-semibold text-charcoal transition-colors group-hover/service:text-white">
                          {service.name}
                        </span>
                        <ArrowUpRight className="h-3.5 w-3.5 shrink-0 text-[var(--key-blue)] transition group-hover/service:-translate-y-0.5 group-hover/service:translate-x-0.5 group-hover/service:text-white" />
                      </div>
                      <div class="mt-1 line-clamp-1 text-[0.69rem] leading-relaxed text-charcoal/52 transition-colors group-hover/service:text-white/72">
                        {service.tagline}
                      </div>
                      {service.isNew && (
                        <span class="mt-2 inline-flex rounded-full bg-[var(--green)] px-2 py-0.5 text-[0.56rem] font-bold uppercase tracking-[0.14em] text-[var(--charcoal)]">
                          New service
                        </span>
                      )}
                    </a>
                  ))}
                </div>

                <a
                  href="/services"
                  class="group/all mt-4 flex items-center justify-between rounded-2xl border border-[var(--navy)]/10 bg-white px-4 py-3 text-sm font-semibold text-[var(--navy)] transition hover:border-[var(--navy)] hover:bg-[var(--navy)] hover:text-white"
                >
                  Compare every service
                  <ArrowUpRight className="h-4 w-4 transition-transform duration-300 group-hover/all:translate-x-0.5 group-hover/all:-translate-y-0.5" />
                </a>
              </div>
              </div>
            </div>
          </div>
        </div>

        {primaryNav.slice(1).map((item) => (
          <a
            href={item.href}
            class:list={[
              "site-nav-link px-4 py-2 text-[0.92rem] transition rounded-full",
              isActive(item.href)
                ? "bg-[var(--off-white)] text-charcoal"
                : "text-charcoal/80 hover:text-charcoal",
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden lg:flex items-center gap-3">
        <a
          href={BOOKING_URL}
          class="btn-primary !py-2.5 !px-5 text-sm"
          data-track-event="consultation_cta_click"
          data-track-placement="navbar"
        >
          Book a Call
        </a>
      </div>

      <button
        type="button"
        class="lg:hidden inline-flex h-11 w-11 items-center justify-center rounded-full hover:bg-[var(--off-white)]"
        aria-label="Open menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-mobile-menu-open
      >
        <Menu className="h-5 w-5" />
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="mobile-menu pointer-events-auto fixed inset-0 z-50 bg-white flex flex-col"
    aria-hidden="true"
  >
    <div class="container-page flex h-[72px] items-center justify-between border-b hairline">
      <span class="font-display text-lg font-semibold">Menu</span>
      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full"
        aria-label="Close menu"
        data-mobile-menu-close
      >
        <X className="h-5 w-5" />
      </button>
    </div>
    <div class="container-page py-8 overflow-y-auto flex-1">
      <nav class="flex flex-col divide-y hairline border-y">
        {primaryNav.map((item) => (
          <a
            href={item.href}
            data-mobile-menu-link
            class="py-5 font-display text-2xl text-charcoal font-semibold"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <a
        href={BOOKING_URL}
        class="btn-primary mt-6 min-h-11 w-full"
        data-mobile-menu-link
        data-track-event="consultation_cta_click"
        data-track-placement="mobile_menu"
      >
        Book a Call
      </a>

      <div class="mt-6">
        <p class="eyebrow mb-3">All Services</p>
        <ul class="grid gap-2">
          {services.map((service) => (
            <li>
              <a
                href={`/services/${service.slug}`}
                data-mobile-menu-link
                class="flex min-h-11 items-center gap-2 py-2 text-charcoal"
              >
                {service.name}
                {service.isNew && (
                  <span
                    class="text-[0.6rem] uppercase tracking-widest px-1.5 py-0.5 rounded"
                    style="background: var(--green); color: var(--charcoal);"
                  >
                    New
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</header>

<style>
  .mobile-menu {
    opacity: 0;
    transform: translateY(12px);
    visibility: hidden;
    transition:
      opacity var(--duration-standard) var(--ease-emphasized),
      transform var(--duration-standard) var(--ease-emphasized),
      visibility 0s linear var(--duration-standard);
  }

  .mobile-menu.is-open {
    opacity: 1;
    transform: none;
    visibility: visible;
    transition:
      opacity var(--duration-standard) var(--ease-emphasized),
      transform var(--duration-standard) var(--ease-emphasized);
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const menu = document.querySelector("#mobile-menu");
  const openButton = document.querySelector("[data-mobile-menu-open]");
  const closeButton = document.querySelector("[data-mobile-menu-close]");
  const menuLinks = document.querySelectorAll("[data-mobile-menu-link]");
  let previousFocus: HTMLElement | null = null;

  function setMobileMenu(open: boolean) {
    if (!menu || !openButton) return;
    const wasOpen = menu.classList.contains("is-open");

    if (open && !wasOpen) {
      previousFocus = document.activeElement instanceof HTMLElement
        ? document.activeElement
        : null;
    }

    menu.classList.toggle("is-open", open);
    menu.setAttribute("aria-hidden", String(!open));
    openButton.setAttribute("aria-expanded", String(open));
    document.body.style.overflow = open ? "hidden" : "";

    if (open) {
      window.requestAnimationFrame(() => {
        if (closeButton instanceof HTMLElement) closeButton.focus();
      });
    } else if (wasOpen) {
      previousFocus?.focus();
    }
  }

  openButton?.addEventListener("click", () => setMobileMenu(true));
  closeButton?.addEventListener("click", () => setMobileMenu(false));
  menuLinks.forEach((link) => link.addEventListener("click", () => setMobileMenu(false)));
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") setMobileMenu(false);
  });
</script>
