---
import { CONSULTATION_URL, services } from "@/lib/services";
---

<footer style="background: var(--navy); color: #fff;">
  <div class="container-page py-20">
    <div class="grid gap-16 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <p class="eyebrow text-white/60">Turnkey Marketing</p>
        <h2 class="display-2 text-white mt-4 text-balance">
          One plan. Clearer spend. Fuller bays.
        </h2>
        <a
          href={CONSULTATION_URL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 mt-8 px-6 py-4 rounded-full font-medium"
          style="background: var(--green); color: var(--charcoal);"
          data-track-event="consultation_cta_click"
          data-track-placement="footer"
        >
          Schedule a Consultation →
        </a>
      </div>

      <div class="lg:col-span-7 grid grid-cols-2 md:grid-cols-3 gap-10 text-sm">
        <div>
          <p class="text-white/50 text-xs uppercase tracking-widest mb-4">Company</p>
          <ul class="space-y-3">
            <li><a href="/about" class="hover:text-[var(--green)]">About</a></li>
            <li><a href="/results" class="hover:text-[var(--green)]">Results</a></li>
            <li><a href="/resources" class="hover:text-[var(--green)]">Resources</a></li>
            <li><a href="/contact" class="hover:text-[var(--green)]">Contact</a></li>
          </ul>
        </div>
        <div>
          <p class="text-white/50 text-xs uppercase tracking-widest mb-4">Services</p>
          <ul class="space-y-3">
            {services.slice(0, 6).map((service) => (
              <li>
                <a href={`/services/${service.slug}`} class="hover:text-[var(--green)]">
                  {service.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p class="text-white/50 text-xs uppercase tracking-widest mb-4">Contact</p>
          <ul class="space-y-3">
            <li>
              <a
                href="tel:9137774144"
                class="hover:text-[var(--green)]"
                data-track-event="phone_click"
                data-track-placement="footer"
              >
                (913) 777-4144
              </a>
            </li>
            <li>
              <a
                href="mailto:hello@turnkeyautomarketing.com"
                class="hover:text-[var(--green)]"
                data-track-event="email_click"
                data-track-placement="footer"
              >
                hello@turnkeyautomarketing.com
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs text-white/50">
      <p>© {new Date().getFullYear()} Turnkey Marketing. Built for auto repair shops.</p>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <a href="/privacy-policy" class="hover:text-[var(--green)]">
          Privacy Policy
        </a>
        <a href="/terms-of-service" class="hover:text-[var(--green)]">
          Terms of Service
        </a>
        <span>Trusted by 300+ shops · 13+ years · ATI & ShopFix partners</span>
      </div>
    </div>
  </div>
</footer>
